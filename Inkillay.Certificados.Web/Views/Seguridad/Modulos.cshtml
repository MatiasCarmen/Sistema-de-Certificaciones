@model IEnumerable<Inkillay.Certificados.Web.Models.Entities.Seg_Modulo>

@{
    ViewData["Title"] = "Módulos del Sistema";
}

<div class="px-4 py-8 max-w-7xl mx-auto">
    
    <!-- Encabezado y Acción Principal -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600">admin_panel_settings</span>
                Catálogo de Módulos App
            </h1>
            <p class="text-sm text-slate-500 mt-1">Gestión de menús y submódulos de seguridad instalados en el sistema.</p>
        </div>
        
        <div class="flex items-center gap-3 shrink-0">
            <button class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-bold text-white shadow transition hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 uppercase tracking-wide">
                <span class="material-symbols-outlined text-[18px]">add_box</span>
                Nuevo Módulo
            </button>
        </div>
    </div>

    <!-- Tabla Principal (Gold Standard) -->
    <div class="bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 align-middle text-sm whitespace-nowrap">
            <thead class="bg-slate-50 border-b border-slate-200 hidden sm:table-header-group">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Identificador</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Componente UI</th>
                    <th scope="col" class="px-6 py-4 text-center font-bold text-slate-500 uppercase tracking-widest text-[10px]">Punto de Montaje</th>
                    <th scope="col" class="px-6 py-4 text-center font-bold text-slate-500 uppercase tracking-widest text-[10px]">Disponibilidad</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-slate-500">
                            <div class="flex flex-col items-center justify-center">
                                <span class="material-symbols-outlined text-5xl mb-3 text-slate-300">extension_off</span>
                                <p class="font-medium">No hay módulos registrados en la estructura base.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var modulo in Model)
                    {
                        <tr class="hover:bg-indigo-50/40 transition-colors group">
                            
                            <!-- Columna: ID -->
                            <td class="px-6 py-4 border-b sm:border-none border-slate-100 block sm:table-cell">
                                <span class="inline-flex font-mono text-xs font-semibold text-slate-500 bg-slate-100 px-2 py-1 rounded border border-slate-200">
                                    #MOD-@modulo.IdModulo.ToString("D4")
                                </span>
                            </td>
                            
                            <!-- Columna: Nombre / Icono -->
                            <td class="px-6 py-4 border-b sm:border-none border-slate-100 block sm:table-cell">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-slate-50 text-indigo-600 flex items-center justify-center flex-shrink-0 border border-slate-200 shadow-sm group-hover:bg-indigo-100 group-hover:border-indigo-200 transition-colors">
                                        <span class="material-symbols-outlined text-[20px]">@modulo.Icono</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-slate-800 text-sm">@modulo.Nombre</span>
                                        <span class="text-[10px] uppercase tracking-wider text-slate-400 font-medium">Elemento Visual</span>
                                    </div>
                                </div>
                            </td>

                            <!-- Columna: Endpoint (Simulada para diseño) -->
                            <td class="px-6 py-4 text-left sm:text-center border-b sm:border-none border-slate-100 block sm:table-cell">
                                <span class="font-mono text-[11px] text-slate-500 bg-slate-50 px-2 py-1 rounded inline-flex items-center gap-1 border border-slate-100">
                                    <span class="material-symbols-outlined text-[14px]">route</span>
                                    /@modulo.Nombre.Replace(" ", "")
                                </span>
                            </td>

                            <!-- Columna: Estado -->
                            <td class="px-6 py-4 text-left sm:text-center block sm:table-cell">
                                @if (modulo.EstadoActivo)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-bold bg-emerald-100 text-emerald-800 border border-emerald-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                        Habilitado
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-bold bg-slate-100 text-slate-500 border border-slate-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                                        Obsoleto
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        
        @if (Model.Any())
        {
            <div class="bg-slate-50 border-t border-slate-200 px-6 py-4 flex items-center justify-between">
                <span class="text-[11px] font-bold text-slate-500 uppercase tracking-widest">
                    Módulos indexados core: <span class="font-black text-slate-900 ml-1">@Model.Count()</span>
                </span>
            </div>
        }
    </div>
</div>
