@model Inkillay.Certificados.Web.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Acceso Corporativo";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inkillay - Acceso Corporativo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700&display=swap" rel="stylesheet" />
    <link href="~/css/login.css" rel="stylesheet" />
    <style>
        body { 
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #f3f2f1 0%, #f5f4f3 100%);
        }
        .login-form:focus-within {
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: box-shadow 0.2s ease;
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-md">
        <!-- Card Principal -->
        <div class="bg-white border border-slate-300 shadow-sm p-8 rounded-sm">
            <!-- Logo y Título -->
            <div class="mb-8 text-center">
                <div class="flex justify-center mb-3">
                    <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-blue-700 flex items-center justify-center rounded-sm">
                        <span class="material-symbols-outlined text-2xl text-white">account_balance</span>
                    </div>
                </div>
                <h1 class="text-2xl font-bold text-slate-900">Inkillay</h1>
                <p class="text-xs text-slate-500 uppercase tracking-widest mt-1">Sistema de Certificaciones</p>
            </div>

            <!-- Formulario -->
            <form asp-action="Login" method="post" id="loginForm" class="login-form space-y-5">
                @Html.AntiForgeryToken()

                <!-- Email Input -->
                <div class="space-y-2">
                    <label for="Correo" class="block text-xs font-bold uppercase text-slate-600 tracking-wider">Correo Electrónico</label>
                    <input type="email" 
                           id="Correo" 
                           name="Correo" 
                           required
                           class="w-full px-4 py-2.5 border-b-2 border-slate-300 focus:border-blue-600 bg-slate-50 focus:bg-white text-sm text-slate-900 placeholder-slate-400 focus:outline-none transition-all"
                           placeholder="tu.correo@institución.edu" />
                </div>

                <!-- Password Input -->
                <div class="space-y-2">
                    <label for="Clave" class="block text-xs font-bold uppercase text-slate-600 tracking-wider">Contraseña</label>
                    <div class="relative">
                        <input type="password" 
                               id="Clave" 
                               name="Clave" 
                               required
                               class="w-full px-4 py-2.5 border-b-2 border-slate-300 focus:border-blue-600 bg-slate-50 focus:bg-white text-sm text-slate-900 placeholder-slate-400 focus:outline-none transition-all"
                               placeholder="••••••••" />
                        <button type="button" onclick="togglePassword()" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                            <span class="material-symbols-outlined" id="toggleIcon">visibility</span>
                        </button>
                    </div>
                </div>

                <!-- Error Message -->
                <div id="msgError" class="hidden p-3 bg-red-50 border-l-4 border-red-600 rounded-sm">
                    <p class="text-xs font-bold text-red-700 uppercase">Credenciales inválidas</p>
                    <p class="text-xs text-red-600 mt-1">Verifica tu correo y contraseña</p>
                </div>

                <!-- Divider -->
                <div class="pt-4 border-t border-slate-200"></div>

                <!-- Submit Button -->
                <button type="submit" 
                        id="btnLogin"
                        class="w-full py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm uppercase rounded-sm transition-all active:scale-95">
                    Acceder al Sistema
                </button>

                <!-- Help Text -->
                <p class="text-xs text-slate-500 text-center">
                    ¿Problemas para acceder? Contacta con 
                    <span class="text-primary font-bold">administración</span>
                </p>
            </form>
        </div>

        <!-- Footer -->
        <div class="mt-6 text-center text-xs text-slate-500">
            <p>© 2026 Inkillay Certificados. Sistema Institucional.</p>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('Clave');
            const icon = document.getElementById('toggleIcon');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility_off';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility';
            }
        }

        // Manejar submit del formulario
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('btnLogin');
            const msgError = document.getElementById('msgError');
            const formData = new FormData(this);
            
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined inline animate-spin">hourglass_top</span> Verificando...';
            msgError.classList.add('hidden');
            
            fetch(this.action, {
                method: 'POST',
                body: formData,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success && data.redirectUrl) {
                    window.location.href = data.redirectUrl;
                } else {
                    msgError.classList.remove('hidden');
                    btn.disabled = false;
                    btn.innerHTML = 'Acceder al Sistema';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                msgError.classList.remove('hidden');
                btn.disabled = false;
                btn.innerHTML = 'Acceder al Sistema';
            });
        });
    </script>

    <style>
        .animate-spin {
            animation: spin 1s linear infinite;
        }
    </style>
</body>
</html>
