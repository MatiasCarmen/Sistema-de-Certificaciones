@model SIGEC.Certificados.Web.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Acceso Corporativo";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inkillay - Acceso Corporativo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-white min-h-screen flex text-slate-900">
    
    <!-- Columna Formulario (Izquierda) -->
    <div class="w-full lg:w-1/2 flex flex-col justify-center px-8 sm:px-16 md:px-24 xl:px-32 relative">
        <div class="max-w-md w-full mx-auto">
            
            <!-- Encabezado -->
            <div class="mb-10 text-center lg:text-left">
                <div class="w-14 h-14 bg-indigo-600 rounded-xl flex items-center justify-center mb-6 mx-auto lg:mx-0 shadow-lg shadow-indigo-200">
                    <span class="material-symbols-outlined text-white text-3xl">verified</span>
                </div>
                <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 mb-2">Bienvenido a SIGEC</h1>
                <p class="text-sm font-medium text-slate-500">Inicia sesión en el Sistema de Certificaciones.</p>
            </div>

            <!-- Formulario -->
            <form asp-action="Login" method="post" id="loginForm" class="space-y-5">
                @Html.AntiForgeryToken()

                <div class="space-y-4">
                    <!-- Input Correo (Floating Label) -->
                    <div class="relative">
                        <input type="email" id="Correo" name="Correo" required
                               class="peer w-full h-12 px-4 pt-4 pb-1 rounded-xl border border-slate-300 bg-white text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-transparent transition-all placeholder-transparent"
                               placeholder="tu.correo@institucion.edu" />
                        <label for="Correo" class="absolute left-4 top-1 text-[10px] font-bold uppercase tracking-wider text-slate-400 transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:top-3.5 peer-placeholder-shown:normal-case peer-placeholder-shown:font-medium peer-focus:top-1 peer-focus:text-[10px] peer-focus:font-bold peer-focus:uppercase peer-focus:text-indigo-600 cursor-text">
                            Correo Electrónico
                        </label>
                    </div>

                    <!-- Input Contraseña (Floating Label) -->
                    <div class="relative">
                        <input type="password" id="Clave" name="Clave" required
                               class="peer w-full h-12 px-4 pt-4 pb-1 rounded-xl border border-slate-300 bg-white text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-transparent transition-all placeholder-transparent pr-12"
                               placeholder="••••••••" />
                        <label for="Clave" class="absolute left-4 top-1 text-[10px] font-bold uppercase tracking-wider text-slate-400 transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:top-3.5 peer-placeholder-shown:normal-case peer-placeholder-shown:font-medium peer-focus:top-1 peer-focus:text-[10px] peer-focus:font-bold peer-focus:uppercase peer-focus:text-indigo-600 cursor-text">
                            Contraseña
                        </label>
                        <button type="button" onclick="togglePassword()" class="absolute right-3 top-1/2 -translate-y-1/2 bg-white text-slate-400 hover:text-indigo-600 focus:outline-none p-1 rounded-md transition-colors">
                            <span class="material-symbols-outlined text-[20px]" id="toggleIcon">visibility</span>
                        </button>
                    </div>
                </div>

                <!-- Error Message -->
                <div id="msgError" class="hidden flex items-start gap-3 p-4 bg-rose-50 border border-rose-200 rounded-xl">
                    <span class="material-symbols-outlined text-rose-500 shrink-0">error</span>
                    <div>
                        <p class="text-sm font-bold text-rose-800">Acceso denegado</p>
                        <p class="text-xs font-medium text-rose-600 mt-0.5">Revisa que tu correo y contraseña sean los correctos.</p>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" id="btnLogin"
                        class="relative w-full h-12 mt-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/30 transition-all active:scale-[0.98] flex items-center justify-center gap-2 overflow-hidden group">
                    <span class="absolute inset-0 w-full h-full bg-indigo-700 scale-x-0 group-hover:scale-x-100 transition-transform origin-left rounded-xl"></span>
                    <span class="relative flex items-center gap-2" id="btnContent">
                        Iniciar Sesión
                        <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                    </span>
                </button>
            </form>

            <div class="mt-8 text-center text-sm font-medium text-slate-500">
                ¿Tienes problemas para acceder? <br class="sm:hidden" />
                <a href="#" class="text-indigo-600 font-bold hover:underline">Contacta a Soporte</a>
            </div>
            
            <!-- Footer Izquierda -->
            <div class="absolute bottom-6 left-0 right-0 text-center text-[11px] font-bold text-slate-400 uppercase tracking-widest hidden lg:block">
                © @DateTime.Now.Year Sigecs Sistema de Gestión de Certificaciones
            </div>
        </div>
    </div>

    <!-- Columna Branding (Derecha) -->
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-slate-900 border-l border-slate-800">
        <!-- Imagen de fondo decorativa o abstracto -->
        <div class="absolute inset-0 opacity-50 bg-[url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/80 to-indigo-900/60 mix-blend-multiply"></div>
        
        <!-- Contenido Central -->
        <div class="relative z-10 w-full h-full flex flex-col items-center justify-center p-12 text-center text-white">
            <div class="w-20 h-20 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center mb-8 border border-white/20 shadow-2xl">
                <span class="material-symbols-outlined text-white text-4xl">school</span>
            </div>
            <h2 class="text-4xl xl:text-5xl font-extrabold tracking-tight mb-6 max-w-lg leading-tight">
                Gestión de Excelencia Académica
            </h2>
            <p class="text-lg text-slate-300 font-medium max-w-md leading-relaxed">
                Plataforma integral diseñada para la automatización de matrículas, el control de operaciones docentes y la emisión de certificaciones oficiales con validez institucional.
            </p>
            
            <!-- Stats Decorativos -->
            <div class="mt-16 grid grid-cols-2 gap-8 w-full max-w-md">
                <div class="p-4 bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10">
                    <p class="text-3xl font-black text-white">100%</p>
                    <p class="text-xs font-bold text-indigo-300 uppercase tracking-wider mt-1">Seguro y Rápido</p>
                </div>
                <div class="p-4 bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10">
                    <p class="text-3xl font-black text-white">24/7</p>
                    <p class="text-xs font-bold text-emerald-300 uppercase tracking-wider mt-1">Disponibilidad</p>
                </div>
            </div>
        </div>
        
        <!-- Decoracion animada sutil -->
        <div class="absolute -bottom-[20%] -left-[10%] w-[60%] h-[60%] rounded-full bg-indigo-600/30 blur-[100px] animate-pulse pointer-events-none"></div>
        <div class="absolute top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-purple-600/20 blur-[80px] animate-pulse delay-1000 pointer-events-none"></div>
    </div>

    <!-- Script de Validacion y Toggles -->
    <script>
        function togglePassword() {
            const input = document.getElementById('Clave');
            const icon = document.getElementById('toggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility_off';
                icon.classList.add('text-indigo-600');
            } else {
                input.type = 'password';
                icon.textContent = 'visibility';
                icon.classList.remove('text-indigo-600');
            }
        }

        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('btnLogin');
            const btnContent = document.getElementById('btnContent');
            const msgError = document.getElementById('msgError');
            const formData = new FormData(this);
            
            btn.disabled = true;
            btnContent.innerHTML = '<span class="material-symbols-outlined inline animate-spin text-[20px]">autorenew</span> Verificando credenciales...';
            msgError.classList.add('hidden');
            
            fetch(this.action, {
                method: 'POST',
                body: formData,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success && data.redirectUrl) {
                    btnContent.innerHTML = '<span class="material-symbols-outlined text-[20px]">check_circle</span> Accediendo...';
                    btn.classList.replace('bg-indigo-600', 'bg-emerald-600');
                    setTimeout(() => window.location.href = data.redirectUrl, 300);
                } else {
                    msgError.classList.remove('hidden');
                    btn.disabled = false;
                    btnContent.innerHTML = 'Iniciar Sesión <span class="material-symbols-outlined text-[20px]">arrow_forward</span>';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                msgError.classList.remove('hidden');
                btn.disabled = false;
                btnContent.innerHTML = 'Iniciar Sesión <span class="material-symbols-outlined text-[20px]">arrow_forward</span>';
            });
        });
    </script>
</body>
</html>
