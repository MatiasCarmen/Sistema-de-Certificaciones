@model Inkillay.Certificados.Web.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Acceso | Sistema Administrativo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="h-full flex items-center justify-center bg-slate-100 antialiased font-sans text-slate-900">
    <main class="w-full max-w-[420px] p-6">
        <div class="bg-white border border-slate-300 shadow-sm rounded-md overflow-hidden">
            <div class="h-1.5 bg-blue-700"></div>
            <header class="p-8 pb-4">
                <div class="flex items-center gap-3 mb-4">
                    <div class="flex-shrink-0 w-10 h-10 bg-slate-100 flex items-center justify-center border border-slate-200 rounded">
                        <i class="fas fa-lock text-slate-600 text-lg"></i>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-slate-800 leading-tight tracking-tight uppercase">Autenticacion</h1>
                        <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Gestion de Certificados</p>
                    </div>
                </div>
                <hr class="border-slate-100">
            </header>

            <div class="px-8 pb-8">
                <form id="loginForm" asp-controller="Account" asp-action="Login" method="post" class="space-y-5">
                    @Html.AntiForgeryToken()

                    <div class="space-y-2">
                        <label for="Correo" class="block text-xs font-bold text-slate-700 uppercase tracking-wider">Identificador de Usuario</label>
                        <input type="email" id="Correo" name="Correo" required
                               class="block w-full px-3 py-2.5 bg-white border border-slate-300 text-sm rounded focus:ring-1 focus:ring-blue-600 focus:border-blue-600 outline-none transition-all placeholder:text-slate-400"
                               placeholder="nombre.usuario@sistema.com">
                    </div>

                    <div class="space-y-2">
                        <div class="flex items-center justify-between">
                            <label for="Clave" class="block text-xs font-bold text-slate-700 uppercase tracking-wider">Contrasena</label>
                        </div>
                        <input type="password" id="Clave" name="Clave" required
                               class="block w-full px-3 py-2.5 bg-white border border-slate-300 text-sm rounded focus:ring-1 focus:ring-blue-600 focus:border-blue-600 outline-none transition-all"
                               placeholder="Entrada de seguridad">
                    </div>

                    <div class="flex items-center justify-between py-1">
                        <label class="flex items-center text-xs text-slate-600 cursor-pointer">
                            <input type="checkbox" class="w-3.5 h-3.5 border-slate-300 rounded text-blue-600 focus:ring-blue-500 mr-2">
                            Recordar en este equipo
                        </label>
                        <a href="#" class="text-xs font-semibold text-blue-700 hover:underline">Recuperar acceso</a>
                    </div>

                    <div id="msgError" class="hidden" role="alert">
                        <div class="flex items-start gap-3 p-3 bg-slate-50 border-l-4 border-red-600 text-slate-800">
                            <i class="fas fa-exclamation-square text-red-600 mt-0.5"></i>
                            <div class="text-[13px]">
                                <p class="font-bold">Error de acceso</p>
                                <p class="text-slate-600">Verifique sus credenciales e intente de nuevo.</p>
                            </div>
                        </div>
                    </div>

                    <button type="submit" id="btnIngresar"
                            class="w-full py-2.5 px-4 bg-slate-800 hover:bg-slate-900 text-white text-sm font-bold rounded shadow transition-colors duration-150 flex items-center justify-center uppercase tracking-widest">
                        <span>Acceder al Sistema</span>
                        <i class="fas fa-chevron-right ml-2 text-[10px]"></i>
                    </button>
                </form>
            </div>

            <footer class="bg-slate-50 border-t border-slate-200 px-8 py-4 flex items-center justify-between">
                <span class="text-[11px] text-slate-500 font-medium">Soporte IT: interno 4050</span>
                <span class="text-[11px] text-slate-400 uppercase font-bold">Confidencial</span>
            </footer>
        </div>

        <p class="mt-6 text-center text-[11px] text-slate-400 leading-relaxed uppercase tracking-tight">
            Sistema creado por Grupo Inkillay.<br>
            El acceso no autorizado sera monitoreado y sancionado.
        </p>
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            const $form = $('#loginForm');
            const $btn = $('#btnIngresar');
            const $error = $('#msgError');

            $form.on('submit', function(e) {
                e.preventDefault(); 
                $error.addClass('hidden');
                $btn.prop('disabled', true).addClass('opacity-50 cursor-not-allowed');
                const originalText = $btn.find('span').text();
                $btn.find('span').text('Verificando...');

              
                $.ajax({
                    url: $form.attr('action'), 
                    type: 'POST',
                    data: $form.serialize(), 
                    success: function(response) {
                        if (response.success) {
                            
                            window.location.href = response.redirectUrl;
                        } else {
                            
                            $error.removeClass('hidden');
                            $error.find('.text-slate-600').text(response.message);
                            resetBtn();
                        }
                    },
                    error: function() {
                        $error.removeClass('hidden');
                        $error.find('.text-slate-600').text('Error critico en el servidor.');
                        resetBtn();
                    }
                });

                function resetBtn() {
                    $btn.prop('disabled', false).removeClass('opacity-50 cursor-not-allowed');
                    $btn.find('span').text(originalText);
                }
            });
        });
    </script>
</body>
</html>
