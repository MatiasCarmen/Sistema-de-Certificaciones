@model CrearUsuarioViewModel
@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white border border-slate-300 rounded-sm shadow-sm">
        <div class="p-4 border-b border-slate-300 bg-slate-50">
            <h3 class="text-xs font-bold text-slate-600 uppercase tracking-wider">Crear Nuevo Usuario</h3>
        </div>

        <form id="formCrearUsuario" method="post" asp-action="Create" class="p-6 space-y-5">
            @Html.AntiForgeryToken()

            <div class="space-y-2">
                <label asp-for="Nombre" class="block text-xs font-bold text-slate-600 uppercase tracking-wider">Nombre Completo</label>
                <input asp-for="Nombre" class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm focus:ring-1 focus:ring-blue-600 focus:border-blue-600" placeholder="Ej: Juan Pérez" required>
                <span asp-validation-for="Nombre" class="text-red-600 text-xs"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Correo" class="block text-xs font-bold text-slate-600 uppercase tracking-wider">Correo Electrónico</label>
                <input asp-for="Correo" type="email" class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm focus:ring-1 focus:ring-blue-600 focus:border-blue-600" placeholder="usuario@example.com" required>
                <span asp-validation-for="Correo" class="text-red-600 text-xs"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="IdRol" class="block text-xs font-bold text-slate-600 uppercase tracking-wider">Rol</label>
                <select asp-for="IdRol" class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm focus:ring-1 focus:ring-blue-600 focus:border-blue-600" required>
                    <option value="">-- Seleccionar Rol --</option>
                    <option value="1">Admin</option>
                    <option value="2">Docente</option>
                    <option value="3">Alumno</option>
                </select>
                <span asp-validation-for="IdRol" class="text-red-600 text-xs"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Clave" class="block text-xs font-bold text-slate-600 uppercase tracking-wider">Contraseña</label>
                <input asp-for="Clave" type="password" class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm focus:ring-1 focus:ring-blue-600 focus:border-blue-600" placeholder="Mínimo 6 caracteres" required>
                <p class="text-xs text-slate-500">La contraseña debe tener al menos 6 caracteres</p>
                <span asp-validation-for="Clave" class="text-red-600 text-xs"></span>
            </div>

            <div class="pt-4 border-t border-slate-300 flex gap-3">
                <button type="submit" class="flex-1 py-2 bg-blue-600 text-white text-xs font-bold uppercase rounded-sm hover:bg-blue-700">
                    Crear Usuario
                </button>
                <a href="@Url.Action("Index")" class="flex-1 py-2 bg-slate-200 text-slate-700 text-xs font-bold uppercase rounded-sm hover:bg-slate-300 text-center">
                    Cancelar
                </a>
            </div>
        </form>

        <div id="mensajeResultado" class="px-6 pb-6"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('formCrearUsuario').addEventListener('submit', async function(e) {
            e.preventDefault();

            const formData = new FormData(this);

            try {
                const response = await fetch('@Url.Action("Create")', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    await Swal.fire({
                        title: '✓ Éxito',
                        text: data.mensaje,
                        icon: 'success',
                        confirmButtonColor: '#0369a1'
                    });
                    window.location.href = '@Url.Action("Index")';
                } else {
                    Swal.fire({
                        title: 'Error',
                        text: data.mensaje,
                        icon: 'error',
                        confirmButtonColor: '#0369a1'
                    });
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({
                    title: 'Error',
                    text: 'No se pudo crear el usuario',
                    icon: 'error',
                    confirmButtonColor: '#0369a1'
                });
            }
        });
    </script>
}
