@model IEnumerable<UsuarioViewModel>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Gestión de Usuarios</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <i class="fas fa-plus"></i> Nuevo Usuario
            </a>
        </div>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Registrado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in Model)
                    {
                        <tr>
                            <td>@usuario.IdUsuario</td>
                            <td>@usuario.Nombre</td>
                            <td>@usuario.Correo</td>
                            <td><span class="badge bg-info">@usuario.NombreRol</span></td>
                            <td>
                                @if (usuario.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td>@usuario.FechaRegistro.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a href="@Url.Action("Edit", new { id = usuario.IdUsuario })" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-danger" onclick="cambiarEstado(@usuario.IdUsuario, @(!usuario.Estado).ToString().ToLower())">
                                    <i class="fas fa-@(usuario.Estado ? "ban" : "check")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i> No hay usuarios registrados
        </div>
    }
</div>

<script>
    function cambiarEstado(idUsuario, nuevoEstado) {
        if (!confirm('¿Está seguro de que desea cambiar el estado de este usuario?')) return;

        fetch('@Url.Action("CambiarEstado")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify({ idUsuario: idUsuario, estado: nuevoEstado })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.mensaje);
                location.reload();
            } else {
                alert('Error: ' + data.mensaje);
            }
        })
        .catch(error => console.error('Error:', error));
    }
</script>
