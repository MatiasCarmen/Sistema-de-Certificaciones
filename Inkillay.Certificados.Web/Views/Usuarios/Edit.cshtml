@model EditarUsuarioViewModel
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white border border-slate-300 rounded-sm shadow-sm">
        <div class="p-4 border-b border-slate-300 bg-slate-50">
            <h3 class="text-xs font-bold text-slate-600 uppercase tracking-wider">Datos del Usuario</h3>
        </div>

        <div class="p-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="block text-xs font-bold text-slate-500 uppercase">ID</label>
                    <p class="text-sm font-mono text-slate-900">#@Model.IdUsuario</p>
                </div>
                <div class="space-y-1">
                    <label class="block text-xs font-bold text-slate-500 uppercase">Estado</label>
                    @if (Model.Estado)
                    {
                        <span class="px-2 py-0.5 bg-green-50 text-green-700 text-xs font-bold uppercase rounded-sm border border-green-200">Activo</span>
                    }
                    else
                    {
                        <span class="px-2 py-0.5 bg-red-50 text-red-700 text-xs font-bold uppercase rounded-sm border border-red-200">Inactivo</span>
                    }
                </div>
            </div>

            <div class="space-y-1">
                <label class="block text-xs font-bold text-slate-500 uppercase">Nombre</label>
                <p class="text-sm text-slate-900">@Model.Nombre</p>
            </div>

            <div class="space-y-1">
                <label class="block text-xs font-bold text-slate-500 uppercase">Correo</label>
                <p class="text-sm text-slate-900">@Model.Correo</p>
            </div>

            <div class="space-y-1">
                <label class="block text-xs font-bold text-slate-500 uppercase">Rol</label>
                <span class="px-2 py-0.5 bg-blue-50 text-blue-700 text-xs font-bold uppercase rounded-sm border border-blue-200">
                    @(Model.IdRol == 1 ? "Admin" : Model.IdRol == 2 ? "Docente" : "Alumno")
                </span>
            </div>

            <div class="p-3 bg-blue-50 border-l-4 border-blue-600 rounded-sm mt-4">
                <p class="text-xs text-blue-900">
                    <strong>Nota:</strong> Los datos solo pueden modificarse desde el panel de administración.
                </p>
            </div>
        </div>

        <div class="p-4 border-t border-slate-300 flex gap-3">
            <button type="button" onclick="cambiarEstado()" 
                    class="flex-1 py-2 @(Model.Estado ? "bg-red-600 hover:bg-red-700" : "bg-green-600 hover:bg-green-700") text-white text-xs font-bold uppercase rounded-sm">
                @(Model.Estado ? "Desactivar" : "Activar")
            </button>
            <a href="@Url.Action("Index")" class="flex-1 py-2 bg-slate-200 text-slate-700 text-xs font-bold uppercase rounded-sm hover:bg-slate-300 text-center">
                Volver
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function cambiarEstado() {
            Swal.fire({
                title: 'Confirmar',
                text: '¿Desea cambiar el estado de este usuario?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0369a1',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, cambiar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('@Url.Action("CambiarEstado")?id=@Model.IdUsuario&estado=@(!Model.Estado)', {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire('Éxito', 'Estado actualizado', 'success')
                                .then(() => location.reload());
                        } else {
                            Swal.fire('Error', data.message || 'No se pudo actualizar', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
