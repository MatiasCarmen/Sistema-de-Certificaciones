@model EditarUsuarioViewModel
@{
    ViewData["Title"] = "Detalle del Usuario";
}

<div class="min-h-screen bg-slate-50/50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
        
        <!-- Alertas Globales de Edición -->
        @if (TempData["Success"] is string successMessage)
        {
            <div class="mb-6 rounded-xl border border-green-200 bg-green-50/80 px-5 py-4 text-sm text-green-800 shadow-sm animate-[fadeIn_0.5s_ease-out]">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-[20px] text-green-600">check_circle</span>
                    @successMessage
                </div>
            </div>
        }

        <!-- Card principal -->
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl">
            
            <!-- Header -->
            <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-8 py-6 text-white relative isolate">
                <div class="absolute -top-12 -right-12 text-indigo-500/20 pointer-events-none">
                    <span class="material-symbols-outlined text-[120px]">badge</span>
                </div>
                
                <div class="relative z-10 flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-bold tracking-tight">Ficha del Usuario</h2>
                        <p class="mt-2 text-indigo-100 flex items-center gap-2">
                            <span class="px-2 py-0.5 bg-indigo-800/50 rounded-md font-mono text-xs border border-indigo-500/30">
                                #@Model.IdUsuario
                            </span>
                            Información y control de estado
                        </p>
                    </div>
                    
                    <!-- Avatar Genérico grande -->
                    <div class="hidden sm:flex h-16 w-16 items-center justify-center rounded-full bg-white/20 border-2 border-white/30 backdrop-blur-sm text-white text-2xl font-bold uppercase shadow-inner">
                        @(Model.Nombre?.FirstOrDefault().ToString() ?? "U")
                    </div>
                </div>
            </div>

            <div class="p-8">
                <!-- Estado Systema -->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between p-4 bg-slate-50 border border-slate-100 rounded-xl mb-8">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center @(Model.Estado ? "bg-green-100 text-green-600" : "bg-red-100 text-red-600")">
                            <span class="material-symbols-outlined text-[20px]">
                                @(Model.Estado ? "verified_user" : "gpp_bad")
                            </span>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Estado del Acceso</p>
                            @if (Model.Estado)
                            {
                                <p class="text-sm font-bold text-green-700 flex items-center gap-1.5 mt-0.5">
                                    <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span> Activo
                                </p>
                            }
                            else
                            {
                                <p class="text-sm font-bold text-red-700 flex items-center gap-1.5 mt-0.5">
                                    <span class="w-2 h-2 rounded-full bg-red-500"></span> Inactivo / Bloqueado
                                </p>
                            }
                        </div>
                    </div>
                    
                    <div class="mt-4 sm:mt-0">
                        <button type="button" onclick="cambiarEstado()" 
                                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-5 py-2 text-sm font-bold uppercase tracking-wider rounded-lg transition-all focus:ring-2 focus:ring-offset-2 shadow-sm
                                @(Model.Estado 
                                    ? "bg-white border-2 border-red-200 text-red-600 hover:bg-red-50 hover:border-red-300 focus:ring-red-500" 
                                    : "bg-white border-2 border-green-200 text-green-600 hover:bg-green-50 hover:border-green-300 focus:ring-green-500")">
                            <span class="material-symbols-outlined text-[18px]">
                                @(Model.Estado ? "block" : "how_to_reg")
                            </span>
                            @(Model.Estado ? "Desactivar Usuario" : "Activar Usuario")
                        </button>
                    </div>
                </div>

                <!-- Detalles Cuadricula -->
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 border-b border-slate-100 pb-2">Datos Registrados</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                    
                    <div class="group">
                        <dt class="text-[11px] font-semibold uppercase text-slate-500 tracking-wider mb-1 flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[14px] text-slate-400">person</span>
                            Nombre Completo
                        </dt>
                        <dd class="text-[15px] font-medium text-slate-900 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100 group-hover:border-indigo-200 transition-colors">
                            @Model.Nombre
                        </dd>
                    </div>

                    <div class="group">
                        <dt class="text-[11px] font-semibold uppercase text-slate-500 tracking-wider mb-1 flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[14px] text-slate-400">mail</span>
                            Correo Electrónico
                        </dt>
                        <dd class="text-[15px] font-medium text-slate-900 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100 group-hover:border-indigo-200 transition-colors">
                            @Model.Correo
                        </dd>
                    </div>

                    <div class="group">
                        <dt class="text-[11px] font-semibold uppercase text-slate-500 tracking-wider mb-1 flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[14px] text-slate-400">admin_panel_settings</span>
                            Nivel de Privilegios (Rol)
                        </dt>
                        <dd class="mt-1">
                            @{
                                var rolNombre = Model.IdRol == 1 ? "Administrador" : Model.IdRol == 2 ? "Docente" : "Alumno";
                                var rolColor = Model.IdRol == 1 ? "bg-purple-100 text-purple-700 ring-purple-600/20" : 
                                               Model.IdRol == 2 ? "bg-blue-100 text-blue-700 ring-blue-600/20" : 
                                               "bg-sky-100 text-sky-700 ring-sky-600/20";
                            }
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-bold uppercase @rolColor ring-1 ring-inset shadow-sm">
                                <span class="material-symbols-outlined text-[14px]">
                                    @(Model.IdRol == 1 ? "shield_person" : Model.IdRol == 2 ? "school" : "face")
                                </span>
                                @rolNombre
                            </span>
                        </dd>
                    </div>
                </div>

                <!-- Nota informativa -->
                <div class="mt-10 rounded-xl bg-blue-50/50 p-4 border border-blue-100 flex items-start gap-3">
                    <span class="material-symbols-outlined text-blue-500 mt-0.5">info</span>
                    <div>
                        <h4 class="text-sm font-bold text-blue-900">Modificación Restringida</h4>
                        <p class="text-xs text-blue-700 mt-1 leading-relaxed">
                            Por motivos de seguridad y auditoría, los datos personales como nombre y correo electrónico solo pueden ser modificados solicitando un ticket directo a administración de base de datos.
                        </p>
                    </div>
                </div>

                <!-- Acciones -->
                <div class="mt-8 flex justify-end border-t border-slate-100 pt-6">
                    <a href="@Url.Action("Index")" 
                       class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 bg-white px-6 py-2.5 text-sm font-bold text-slate-700 shadow-sm transition hover:bg-slate-50 hover:border-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 uppercase tracking-wide">
                        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                        Volver al Padrón
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<form id="csrfForm" class="hidden">@Html.AntiForgeryToken()</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function cambiarEstado() {
            Swal.fire({
                title: 'Confirmar Acción',
                text: '¿Estás seguro de que deseas cambiar el estado de acceso de este usuario?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#4f46e5', // indigo-600
                cancelButtonColor: '#94a3b8',  // slate-400
                confirmButtonText: 'Sí, aplicar cambio',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    
                    // Mostrar loading spinner en Swal
                    Swal.fire({
                        title: 'Procesando...',
                        text: 'Actualizando privilegios en el sistema',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    const token = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]').value;
                    fetch('@Url.Action("CambiarEstado")?id=@Model.IdUsuario&estado=@(!Model.Estado)', {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': token }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                title: '¡Actualizado!',
                                text: 'El estado del usuario ha sido modificado exitosamente.',
                                icon: 'success',
                                confirmButtonColor: '#4f46e5'
                            }).then(() => location.reload());
                        } else {
                            Swal.fire({
                                title: 'Error',
                                text: data.message || 'No se pudo actualizar el registro en la base de datos.',
                                icon: 'error',
                                confirmButtonColor: '#4f46e5'
                            });
                        }
                    })
                    .catch(error => {
                        Swal.fire({
                            title: 'Error de Red',
                            text: 'Ocurrió un problema de conexión al intentar el cambio.',
                            icon: 'error',
                            confirmButtonColor: '#4f46e5'
                        });
                    });
                }
            });
        }
    </script>
}
