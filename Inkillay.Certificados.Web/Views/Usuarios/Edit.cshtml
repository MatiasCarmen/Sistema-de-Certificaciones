@model EditarUsuarioViewModel
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="fas fa-user-edit"></i> Editar Usuario</h4>
                </div>
                <div class="card-body">
                    <form>
                        <div class="mb-3">
                            <label class="form-label">ID Usuario</label>
                            <input type="text" class="form-control" value="@Model.IdUsuario" disabled>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" value="@Model.Nombre" disabled>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Correo</label>
                            <input type="email" class="form-control" value="@Model.Correo" disabled>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Rol</label>
                            <select class="form-select" disabled>
                                <option>@(Model.IdRol == 1 ? "Admin" : Model.IdRol == 2 ? "Docente" : "Alumno")</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Estado</label>
                            <div>
                                @if (Model.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Los datos de este usuario solo pueden ser modificados desde la base de datos o contactando al administrador del sistema.
                        </div>

                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-danger" onclick="cambiarEstado()">
                                <i class="fas fa-toggle-@(Model.Estado ? "off" : "on")"></i> 
                                @(Model.Estado ? "Desactivar Usuario" : "Activar Usuario")
                            </button>
                        </div>

                        <div class="mt-3">
                            <a href="@Url.Action("Index")" class="btn btn-secondary w-100">
                                <i class="fas fa-arrow-left"></i> Volver
                            </a>
                        </div>
                    </form>

                    <div id="mensajeResultado" class="mt-3"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function cambiarEstado() {
        if (!confirm('¿Está seguro de que desea cambiar el estado de este usuario?')) return;

        fetch('@Url.Action("CambiarEstado")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify({ 
                idUsuario: @Model.IdUsuario, 
                estado: @(Model.Estado ? "false" : "true") 
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.mensaje);
                location.reload();
            } else {
                alert('Error: ' + data.mensaje);
            }
        })
        .catch(error => console.error('Error:', error));
    }
</script>
