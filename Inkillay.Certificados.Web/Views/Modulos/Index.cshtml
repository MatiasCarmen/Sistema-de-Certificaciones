@model IEnumerable<SIGEC.Certificados.Web.Models.Entities.Modulo>
@{
    ViewData["Title"] = "Gestión de Módulos (Grupos)";
}

<div class="px-4 py-8">
    
    <!-- Encabezado y Acción Principal -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600">view_module</span>
                Listado de Módulos
            </h1>
            <p class="text-sm text-slate-500 mt-1">Administra los grupos, ediciones y periodos activos.</p>
        </div>
        
        <a asp-action="Create" class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-bold text-white shadow transition hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 uppercase tracking-wide shrink-0">
            <span class="material-symbols-outlined text-[18px]">add_box</span>
            Nuevo Módulo
        </a>
    </div>

    <!-- Filtros / Búsqueda (Placeholder Visual para el futuro) -->
    <div class="bg-white rounded-t-xl border-x border-t border-slate-200 p-4 shadow-sm flex items-center justify-between">
        <div class="relative w-full max-w-sm">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                <span class="material-symbols-outlined text-[18px]">search</span>
            </span>
            <input type="text" placeholder="Buscar módulo por edición..." class="w-full pl-10 pr-4 py-2 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition shadow-sm outline-none">
        </div>
        <div class="text-sm text-slate-500 font-medium">
            Total: <span class="text-slate-900 font-bold">@Model.Count()</span> registros
        </div>
    </div>

    <!-- Tabla Principal (Gold Standard) -->
    <div class="bg-white shadow-sm border border-slate-200 rounded-b-xl overflow-hidden overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 align-middle text-sm whitespace-nowrap">
            <thead class="bg-slate-50 border-b border-slate-200 hidden sm:table-header-group">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Identificador</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Curso Vinculado (ID)</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Edición</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Inversión</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Estado</th>
                    <th scope="col" class="px-6 py-4 text-right font-bold text-slate-500 uppercase tracking-widest text-[10px] rounded-tr-xl">Acciones Rápidas</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center justify-center text-slate-400">
                                <span class="material-symbols-outlined text-6xl mb-3 text-slate-300">inbox</span>
                                <p class="text-base font-medium text-slate-600">No hay módulos registrados</p>
                                <p class="text-sm mt-1">Crea el primer módulo para el sistema.</p>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr class="hover:bg-indigo-50/40 transition-colors group">
                        
                        <!-- Columna: ID -->
                        <td class="px-6 py-4">
                            <span class="inline-flex font-mono text-xs font-semibold text-slate-500 bg-slate-100 px-2 py-1 rounded">
                                #@item.IdModulo.ToString("D4")
                            </span>
                        </td>
                        
                        <!-- Columna: Nombre/ID Curso -->
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center flex-shrink-0 shadow-sm border border-indigo-200">
                                    <span class="material-symbols-outlined text-[16px]">menu_book</span>
                                </div>
                                <div class="flex flex-col">
                                    <span class="font-bold text-slate-800">Curso ID: @item.IdCurso</span>
                                    <span class="text-[11px] text-slate-400 font-medium">Programa Académico</span>
                                </div>
                            </div>
                        </td>
                        
                        <!-- Columna: Edición -->
                        <td class="px-6 py-4">
                            <span class="font-semibold text-indigo-700 bg-indigo-50 px-3 py-1 rounded-full border border-indigo-100 text-xs shadow-sm">
                                @item.EdicionCurso
                            </span>
                        </td>
                        
                        <!-- Columna: Costo -->
                        <td class="px-6 py-4">
                            <span class="font-medium text-slate-700">
                                S/ @item.CostoCurso.ToString("N2")
                            </span>
                        </td>

                        <!-- Columna: Estado -->
                        <td class="px-6 py-4">
                            @if (item.Estado == 'A')
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800 border border-emerald-200 shadow-sm">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-sm"></span>
                                    Activo
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-slate-100 text-slate-600 border border-slate-200 shadow-sm">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                                    Inactivo
                                </span>
                            }
                        </td>

                        <!-- Columna: Acciones -->
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a href="#" class="p-2 text-indigo-600 hover:bg-indigo-100 rounded-lg transition-colors group/btn tooltip" title="Ver Alumnos">
                                    <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">groups</span>
                                </a>
                                <a href="@Url.Action("Edit", "Modulos", new { id = item.IdModulo })" class="p-2 text-amber-600 hover:bg-amber-100 rounded-lg transition-colors group/btn tooltip" title="Editar">
                                    <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">edit</span>
                                </a>
                                <button type="button" onclick="eliminarModulo(@item.IdModulo)" class="p-2 text-rose-600 hover:bg-rose-100 rounded-lg transition-colors group/btn tooltip" title="Eliminar">
                                    <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">delete</span>
                                </button>
                            </div>
                            <!-- Botón visible en móviles -->
                            <div class="flex items-center justify-end sm:hidden">
                                <span class="material-symbols-outlined text-slate-400">more_vert</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación Mock (Opcional visualmente) -->
    @if(Model.Any())
    {
        <div class="flex items-center justify-between mt-6 px-2">
            <span class="text-sm font-medium text-slate-500">Mostrando todos los registros activos</span>
            <div class="flex gap-2">
                <button disabled title="Anterior" class="w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center text-slate-400 opacity-50 cursor-not-allowed">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </button>
                <button class="w-8 h-8 rounded-full border border-indigo-500 bg-indigo-500 flex items-center justify-center text-white font-bold text-xs shadow-md">
                    1
                </button>
                <button disabled title="Siguiente" class="w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center text-slate-400 opacity-50 cursor-not-allowed">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </button>
            </div>
        </div>
    }
</div>

<form id="antiforgery-form" method="post" class="hidden">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
<script>
    function eliminarModulo(id) {
        Swal.fire({
            title: '¿Eliminar Módulo?',
            text: 'Esta acción es irreversible y borrará el módulo. Fallará si el módulo tiene alumnos o pagos vinculados.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#e11d48',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
            customClass: {
                popup: 'rounded-2xl shadow-xl border border-slate-200',
                confirmButton: 'rounded-lg px-6 py-2.5 font-bold',
                cancelButton: 'rounded-lg px-6 py-2.5 font-bold text-slate-700 bg-slate-100 hover:bg-slate-200'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                const tokenInput = document.querySelector('#antiforgery-form input[name="__RequestVerificationToken"]');
                const body = new URLSearchParams();
                body.append('id', id);
                body.append('__RequestVerificationToken', tokenInput.value);

                fetch('@Url.Action("Eliminar", "Modulos")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString()
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            title: 'Eliminado',
                            text: 'El módulo fue eliminado correctamente.',
                            icon: 'success',
                            confirmButtonColor: '#4f46e5'
                        }).then(() => location.reload());
                    } else {
                        Swal.fire({
                            title: 'Atención',
                            text: data.mensaje || 'Error al eliminar el módulo.',
                            icon: 'error',
                            confirmButtonColor: '#4f46e5'
                        });
                    }
                })
                .catch(() => {
                    Swal.fire({
                        title: 'Error',
                        text: 'Ocurrió un error al contactar al servidor.',
                        icon: 'error',
                        confirmButtonColor: '#4f46e5'
                    });
                });
            }
        });
    }
</script>
}
