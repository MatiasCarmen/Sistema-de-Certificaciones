@model SIGEC.Certificados.Web.Models.ViewModels.CrearModuloViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Editar Módulo";
}

<style>
    .input-error { border-color: #ef4444 !important; background-color: #fef2f2 !important; }
    .error-text { color: #ef4444; font-size: 0.75rem; margin-top: 0.25rem; display: none; }
    
    /* Ocultar flecha nativa de select para evitar "doble flecha" */
    select {
        -webkit-appearance: none !important;
        -moz-appearance: none !important;
        appearance: none !important;
        background-image: none !important; /* IMPORTANTE: Para anular el plugin tailwind-forms */
    }
    select::-ms-expand {
        display: none !important;
    }
</style>

<!-- CONTENIDO PRINCIPAL -->
<div class="flex-1 overflow-y-auto p-4 md:p-8 bg-gray-50">
    <div class="max-w-6xl mx-auto space-y-6">
        
        <!-- Botón Volver -->
        <div class="flex justify-end">
            <a asp-action="Index" class="text-blue-600 text-sm font-semibold hover:underline flex items-center gap-1">
                ← Volver al listado
            </a>
        </div>

        <!-- CARD FORMULARIO -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8">
            <form asp-action="Edit" method="post" id="moduleForm" novalidate>
                <input type="hidden" name="idModulo" value="@ViewBag.IdModulo" />
                @Html.AntiForgeryToken()
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="mb-6 rounded-lg bg-red-50 p-4 border border-red-200">
                        <div asp-validation-summary="All" class="text-sm text-red-700"></div>
                    </div>
                }

                <!-- SECCIÓN 1: DETALLES GENERALES -->
                <div class="mb-10">
                    <div class="flex items-center gap-2 mb-6 text-blue-700">
                        <span class="material-symbols-outlined text-[20px]">info</span>
                        <h2 class="font-bold text-lg tracking-tight">Información del Módulo</h2>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-x-6 gap-y-4">
                        <div class="md:col-span-3">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide"># Módulo *</label>
                            <input asp-for="Sumilla" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all" placeholder="MOD-XXXX">
                            <p class="error-text">Campo obligatorio</p>
                        </div>
                        <div class="md:col-span-6">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Nombre del Curso *</label>
                            <div class="relative">
                                <select asp-for="IdCurso" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg pl-4 pr-10 py-2.5 focus:ring-2 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all appearance-none cursor-pointer">
                                    <option value="">Seleccione un curso...</option>
                                    @if(Model.Cursos != null)
                                    {
                                        foreach (var curso in Model.Cursos)
                                        {
                                            <option value="@curso.IdCurso">@curso.Nombre</option>
                                        }
                                    }
                                </select>
                                <button type="button" class="absolute right-3 top-2.5 text-gray-400 pointer-events-none">
                                    <span class="material-symbols-outlined text-[20px]">expand_more</span>
                                </button>
                            </div>
                            <p class="error-text">Debe seleccionar un curso</p>
                        </div>
                        <div class="md:col-span-3">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Estado *</label>
                            <select asp-for="EstadoMatricula" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg px-4 py-2.5 outline-none focus:border-blue-500 transition-all appearance-none cursor-pointer">
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN 2: PLANIFICACIÓN -->
                <div class="mb-10">
                    <div class="flex items-center gap-2 mb-6 text-blue-700">
                        <span class="material-symbols-outlined text-[20px]">calendar_month</span>
                        <h2 class="font-bold text-lg tracking-tight">Planificación y Asignación</h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-x-6 gap-y-4">
                        <div class="md:col-span-8">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Docente Asignado *</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-blue-500">
                                    <span class="material-symbols-outlined text-[20px]">search</span>
                                </div>
                                <select asp-for="IdDocente" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg pl-10 pr-10 py-2.5 focus:ring-2 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all appearance-none cursor-pointer">
                                    <option value="">Buscar docente por nombre o DNI...</option>
                                    @if(Model.Docentes != null)
                                    {
                                        foreach (var docente in Model.Docentes)
                                        {
                                            <option value="@docente.IdUsuario">@docente.Nombre</option>
                                        }
                                    }
                                </select>
                                <button type="button" class="absolute right-3 top-2.5 text-gray-400 pointer-events-none">
                                    <span class="material-symbols-outlined text-[20px]">expand_more</span>
                                </button>
                            </div>
                            <p class="error-text">Debe asignar un docente</p>
                        </div>
                        <div class="md:col-span-4">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Edición *</label>
                            <input asp-for="EdicionCurso" type="text" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg px-4 py-2.5 focus:border-blue-500 outline-none" placeholder="Ej: 2024-I">
                            <p class="error-text">Campo obligatorio</p>
                        </div>

                        <div class="md:col-span-4">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">F. Inicio Clases *</label>
                            <input asp-for="FechaInicioClases" type="date" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg px-4 py-2.5 focus:border-blue-500 outline-none">
                            <p class="error-text">Seleccione fecha</p>
                        </div>
                        <div class="md:col-span-4">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Apertura Matrícula *</label>
                            <input asp-for="FechaInicioMatricula" type="date" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg px-4 py-2.5 focus:border-blue-500 outline-none">
                            <p class="error-text">Seleccione fecha</p>
                        </div>
                        <div class="md:col-span-4">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Modalidad *</label>
                            <select asp-for="Modalidad" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg px-4 py-2.5 outline-none focus:border-blue-500 appearance-none cursor-pointer">
                                <option value="P">Presencial</option>
                                <option value="R">Virtual / Remoto</option>
                                <option value="H">Híbrido</option>
                            </select>
                        </div>

                        <div class="md:col-span-4">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Inversión (Costo) *</label>
                            <div class="relative">
                                <span class="absolute left-4 top-2.5 text-gray-400 font-bold">S/</span>
                                <input asp-for="CostoCurso" type="number" step="0.01" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg pl-9 pr-4 py-2.5 focus:border-blue-500 outline-none" placeholder="0.00">
                            </div>
                            <p class="error-text">Ingrese monto</p>
                        </div>
                        <div class="md:col-span-4">
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Capacidad Alumnos *</label>
                            <input asp-for="CapacidadAlumno" type="number" required class="w-full bg-[#f9fafb] border border-gray-300 rounded-lg px-4 py-2.5 focus:border-blue-500 outline-none" placeholder="0">
                            <p class="error-text">Ingrese capacidad</p>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN 3: AUDITORÍA (Solo Lectura) -->
                <div class="pt-8 border-t border-gray-100 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-4 bg-gray-50 rounded-lg border border-gray-100">
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Responsable Registrador</span>
                        <div class="flex justify-between mt-1 text-sm">
                            <span class="font-bold text-gray-700">@(string.IsNullOrEmpty(User.Identity?.Name) ? "Admin Local" : User.Identity.Name)</span>
                            <span class="text-gray-400 italic">Hoy</span>
                        </div>
                    </div>
                    <div class="p-4 bg-gray-50 rounded-lg border border-gray-100">
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Creación del Sistema</span>
                        <div class="flex justify-between mt-1 text-sm">
                            <span class="font-bold text-gray-700">Sistema SGA</span>
                            <span class="text-gray-400 italic">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                </div>

                <!-- ACCIONES -->
                <div class="mt-10 flex flex-col sm:flex-row justify-end gap-3 border-t pt-6">
                    <a asp-action="Index" class="px-8 py-3 text-sm font-bold text-gray-500 hover:bg-gray-100 rounded-lg transition-all text-center">Cancelar</a>
                    <button type="submit" class="px-10 py-3 bg-amber-600 hover:bg-amber-700 text-white text-sm font-bold rounded-lg shadow-lg shadow-amber-200 transition-all flex items-center justify-center gap-2 uppercase tracking-wide">
                        <span class="material-symbols-outlined text-[18px]">save</span>
                        Actualizar Módulo
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('moduleForm').addEventListener('submit', function(e) {
            let hasError = false;
            const requiredFields = this.querySelectorAll('[required]');
            
            requiredFields.forEach(field => {
                const errorText = field.parentElement.querySelector('.error-text');
                if (!field.value.trim()) {
                    field.classList.add('input-error');
                    if (errorText) errorText.style.display = 'block';
                    hasError = true;
                } else {
                    field.classList.remove('input-error');
                    if (errorText) errorText.style.display = 'none';
                }
            });

            if (hasError) {
                // Prevenimos el POST si hay errores
                e.preventDefault(); 
            } else {
                // UI transition nativa adaptada 
                const btn = this.querySelector('button[type="submit"]');
                btn.innerHTML = '<div class="h-4 w-4 animate-spin rounded-full border-2 border-white border-t-transparent mr-2"></div> Procesando...';
                // Permitimos el POST sin desactivar ni alert(), es MVC puro.
                btn.style.pointerEvents = 'none';
            }
        });

        // Limpiar errores al escribir
        document.querySelectorAll('input, select').forEach(el => {
            el.addEventListener('input', function() {
                if (this.value.trim()) {
                    this.classList.remove('input-error');
                    const errorText = this.parentElement.querySelector('.error-text');
                    if (errorText) errorText.style.display = 'none';
                }
            });
        });
    </script>
}