@model Inkillay.Certificados.Web.Models.Entities.Modulo
@{
    ViewData["Title"] = "Crear Nuevo Módulo";
}

<div class="max-w-xl mx-auto py-8">
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
            <h2 class="text-lg font-semibold text-slate-800">Registrar Grupo de Curso</h2>
        </div>
        
        <form asp-action="Create" class="p-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="block text-sm font-medium text-slate-700">Curso</label>
                    <select asp-for="IdCurso" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                        <option value="">-- Seleccionar --</option>
                        @foreach(var curso in ViewBag.Cursos)
                        {
                            <option value="@curso.IdCurso">@curso.Nombre</option>
                        }
                    </select>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700">ID Docente</label>
                    <input asp-for="IdDocente" type="number" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" />
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700">Edición</label>
                    <input asp-for="EdicionCurso" type="text" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" placeholder="Ej. 2026-I" />
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700">Costo Curso (S/)</label>
                    <input asp-for="CostoCurso" type="number" step="0.01" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" />
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700">Capacidad Alumnos</label>
                    <input asp-for="CapacidadAlumno" type="number" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" />
                </div>
                
                <div class="col-span-2">
                    <label class="block text-sm font-medium text-slate-700">Modalidad</label>
                    <select asp-for="Modalidad" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                        <option value="P">Presencial</option>
                        <option value="H">Híbrido</option>
                        <option value="R">Remoto / Virtual</option>
                    </select>
                </div>
            </div>

            <div class="mt-6 flex justify-end gap-3">
                <a asp-action="Index" class="px-4 py-2 border border-slate-300 text-slate-700 rounded-md hover:bg-slate-50">Cancelar</a>
                <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700">Guardar</button>
            </div>
        </form>
    </div>
</div>
