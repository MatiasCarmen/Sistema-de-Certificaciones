@model Inkillay.Certificados.Web.Models.ViewModels.MatricularViewModel
@{
    ViewData["Title"] = "Matricular Alumno";
}

<div class="p-6">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Matricular Alumno</h2>
    <div class="mx-auto max-w-2xl">

        <!-- Card principal -->
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl">
            
            <!-- Header mejorado -->
            <div class="bg-gradient-to-r from-indigo-600 via-violet-600 to-indigo-700 px-8 py-10 text-white">
                <div class="flex items-center gap-5">
                    <div class="rounded-2xl bg-white/20 p-4 backdrop-blur-md">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-3xl font-bold tracking-tight">Modulor Alumno</h1>
                        <p class="mt-2 text-indigo-100 text-lg">Vincula un estudiante a un curso de forma rápida y profesional</p>
                    </div>
                </div>
            </div>

            <form id="formModulor" method="post" class="p-8 space-y-10">
                @Html.AntiForgeryToken()

                <!-- ALUMNO: TomSelect searchable (ideal para 2000+ alumnos) -->
                <div class="space-y-3">
                    <label class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m5-2v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Estudiante
                    </label>
                    <select id="idAlumno" name="idAlumno" class="tomselect" required>
                        <option value="">-- Busca y selecciona un alumno --</option>
                        @foreach (var alumno in Model.Alumnos)
                        {
                            <option value="@alumno.IdUsuario">@alumno.Nombre (@alumno.Correo)</option>
                        }
                    </select>
                    <p class="text-xs text-slate-500">Escribe nombre o correo • Soporta +2000 alumnos</p>
                </div>

                <!-- CURSO: También TomSelect (por si tienes muchos cursos) -->
                <div class="space-y-3">
                    <label class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18 9.246 18 10.832 18.477 12 19.253zm0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18 14.754 18 13.168 18.477 12 19.253z" />
                        </svg>
                        Curso
                    </label>
                    <select id="idCurso" name="idCurso" class="tomselect" required>
                        <option value="">-- Selecciona el curso --</option>
                        @foreach (var curso in Model.Cursos)
                        {
                            <option value="@curso.IdCurso">@curso.Nombre</option>
                        }
                    </select>
                </div>

                <!-- MODALIDAD: Cards modernas con iconos SVG reales (sin emojis) -->
                <div class="space-y-4">
                    <label class="text-sm font-semibold text-slate-700 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 01-2-2H7a2 2 0 01-2 2v16m14 0h-4m-6 0H5" />
                        </svg>
                        Modalidad
                    </label>

                    <div class="grid grid-cols-3 gap-4">
                        <!-- Presencial -->
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="modalidad" value="P" class="peer sr-only" checked>
                            <div class="h-full p-6 border-2 border-slate-200 rounded-3xl text-center transition-all peer-checked:border-emerald-500 peer-checked:bg-emerald-50 peer-checked:shadow-inner group-hover:border-slate-300">
                                <div class="mx-auto w-12 h-12 flex items-center justify-center text-emerald-600">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2v-2a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2" />
                                    </svg>
                                </div>
                                <p class="mt-4 text-sm font-bold text-slate-700 peer-checked:text-emerald-700">Presencial</p>
                            </div>
                        </label>

                        <!-- Virtual -->
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="modalidad" value="R" class="peer sr-only">
                            <div class="h-full p-6 border-2 border-slate-200 rounded-3xl text-center transition-all peer-checked:border-violet-500 peer-checked:bg-violet-50 peer-checked:shadow-inner group-hover:border-slate-300">
                                <div class="mx-auto w-12 h-12 flex items-center justify-center text-violet-600">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2" />
                                    </svg>
                                </div>
                                <p class="mt-4 text-sm font-bold text-slate-700 peer-checked:text-violet-700">Virtual</p>
                            </div>
                        </label>

                        <!-- Híbrido -->
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="modalidad" value="H" class="peer sr-only">
                            <div class="h-full p-6 border-2 border-slate-200 rounded-3xl text-center transition-all peer-checked:border-amber-500 peer-checked:bg-amber-50 peer-checked:shadow-inner group-hover:border-slate-300">
                                <div class="mx-auto w-12 h-12 flex items-center justify-center text-amber-600">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276L20 10V18H4V6L8.553 3.724 12 6 15.447 3.724 20 6" />
                                    </svg>
                                </div>
                                <p class="mt-4 text-sm font-bold text-slate-700 peer-checked:text-amber-700">Híbrido</p>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Botones -->
                <div class="flex gap-4 pt-4">
                    <button type="submit" id="btnSubmit"
                            class="flex-1 bg-gradient-to-r from-indigo-600 to-violet-600 text-white font-semibold py-4 rounded-2xl shadow-lg hover:shadow-xl active:scale-[0.97] transition-all flex items-center justify-center gap-3 text-base">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                        </svg>
                        REGISTRAR MATRÍCULA
                    </button>

                    <a asp-action="Index" 
                       class="px-8 py-4 bg-slate-100 text-slate-700 font-semibold rounded-2xl hover:bg-slate-200 transition-all flex items-center justify-center">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- TomSelect CDN (ligero y profesional) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.css">
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Inicializar TomSelect (buscable, rápido incluso con 2000+ alumnos)
        new TomSelect("#idAlumno", {
            maxOptions: 200,
            searchField: ['text'],
            placeholder: "Busca por nombre o correo...",
            highlight: true,
            plugins: ['remove_button'],
            render: {
                option: function(data) {
                    return `<div class="flex items-center gap-3 py-2"><span class="font-medium">${data.text}</span></div>`;
                }
            }
        });

        new TomSelect("#idCurso", {
            placeholder: "Selecciona el curso...",
            maxOptions: 100
        });

        // Submit con SweetAlert mejorado
        document.getElementById('formModulor').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = `
                <svg class="animate-spin h-5 w-5 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                </svg>
                Procesando...
            `;

            const formData = new FormData(this);

            Swal.fire({
                title: 'Registrando matrícula',
                text: 'Esto puede tardar unos segundos',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            try {
                const response = await fetch('@Url.Action("Modulor")', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();

                if (data.success) {
                    await Swal.fire({
                        title: '¡Matrícula registrada!',
                        text: data.mensaje,
                        icon: 'success',
                        timer: 2500,
                        showConfirmButton: false
                    });
                    window.location.href = '@Url.Action("Index")';
                } else {
                    Swal.fire('Error', data.mensaje || 'No se pudo completar', 'error');
                }
            } catch (err) {
                Swal.fire('Error de conexión', 'Inténtalo nuevamente', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                    </svg>
                    REGISTRAR MATRÍCULA
                `;
            }
        });
    </script>
}