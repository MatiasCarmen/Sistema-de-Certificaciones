@model Inkillay.Certificados.Web.Models.ViewModels.MatricularViewModel
@{
    ViewData["Title"] = "Matricular Alumno";
}

<div class="min-h-screen bg-slate-50/50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
        
        <!-- Card principal -->
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl">
            
            <!-- Header -->
            <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-8 py-6 text-white relative isolate">
                <div class="absolute -top-12 -right-8 text-indigo-500/20 pointer-events-none transform -rotate-12">
                    <span class="material-symbols-outlined text-[140px]">school</span>
                </div>
                
                <div class="relative z-10 flex items-center justify-between">
                    <div>
                        <div class="flex items-center gap-3">
                            <a href="@Url.Action("VerAlumnos")" class="flex items-center justify-center w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm" title="Volver al padrón">
                                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                            </a>
                            <h2 class="text-2xl font-bold tracking-tight">Matricular Estudiante</h2>
                        </div>
                        <p class="mt-2 text-indigo-100 ml-11">Vincula un estudiante a un curso de forma rápida y profesional</p>
                    </div>
                </div>
            </div>

            <!-- Formulario -->
            <form id="formModulor" method="post" class="p-8">
                @Html.AntiForgeryToken()

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    
                    <!-- Columna Izquierda: Selección -->
                    <div class="space-y-8">
                        
                        <!-- ALUMNO -->
                        <div>
                            <h3 class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 border-b border-slate-100 pb-2">
                                <span class="material-symbols-outlined text-[16px]">person_search</span>
                                Buscar Alumno
                            </h3>
                            <div class="relative">
                                <select id="idAlumno" name="idAlumno" required>
                                    <option value="">-- Busca y selecciona un alumno --</option>
                                    @if(Model.Alumnos != null)
                                    {
                                        foreach (var alumno in Model.Alumnos)
                                        {
                                            <option value="@alumno.IdUsuario">@alumno.Nombre (@alumno.Correo)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <p class="text-[11px] text-slate-400 mt-2 ml-1 flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">info</span>
                                Escribe nombre o correo • Soporta +2000 cuentas
                            </p>
                        </div>

                        <!-- CURSO -->
                        <div>
                            <h3 class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 border-b border-slate-100 pb-2">
                                <span class="material-symbols-outlined text-[16px]">local_library</span>
                                Asignar Curso / Módulo
                            </h3>
                            <div class="relative">
                                <select id="idCurso" name="idCurso" required>
                                    <option value="">-- Busca y selecciona el curso --</option>
                                    @if(Model.Cursos != null)
                                    {
                                        foreach (var curso in Model.Cursos)
                                        {
                                            <option value="@curso.IdCurso">@curso.Nombre</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Columna Derecha: Modalidad -->
                    <div>
                        <h3 class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 border-b border-slate-100 pb-2">
                            <span class="material-symbols-outlined text-[16px]">cast_for_education</span>
                            Configurar Modalidad
                        </h3>
                        
                        <div class="grid grid-cols-1 gap-4">
                            <!-- Presencial -->
                            <label class="relative cursor-pointer group">
                                <input type="radio" name="modalidad" value="P" class="peer sr-only" checked>
                                <div class="p-4 border-2 border-slate-200 rounded-xl flex items-center gap-4 transition-all peer-checked:border-emerald-500 peer-checked:bg-emerald-50 peer-checked:shadow-inner group-hover:border-slate-300">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center bg-emerald-100 text-emerald-600">
                                        <span class="material-symbols-outlined text-[24px]">apartment</span>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-slate-700 peer-checked:text-emerald-800">Presencial</p>
                                        <p class="text-xs text-slate-500 peer-checked:text-emerald-600">El alumno asiste físicamente a las instalaciones.</p>
                                    </div>
                                </div>
                            </label>

                            <!-- Virtual -->
                            <label class="relative cursor-pointer group">
                                <input type="radio" name="modalidad" value="R" class="peer sr-only">
                                <div class="p-4 border-2 border-slate-200 rounded-xl flex items-center gap-4 transition-all peer-checked:border-violet-500 peer-checked:bg-violet-50 peer-checked:shadow-inner group-hover:border-slate-300">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center bg-violet-100 text-violet-600">
                                        <span class="material-symbols-outlined text-[24px]">computer</span>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-slate-700 peer-checked:text-violet-800">Remoto / Virtual</p>
                                        <p class="text-xs text-slate-500 peer-checked:text-violet-600">Clases síncronas a través de plataforma online.</p>
                                    </div>
                                </div>
                            </label>

                            <!-- Híbrido -->
                            <label class="relative cursor-pointer group">
                                <input type="radio" name="modalidad" value="H" class="peer sr-only">
                                <div class="p-4 border-2 border-slate-200 rounded-xl flex items-center gap-4 transition-all peer-checked:border-amber-500 peer-checked:bg-amber-50 peer-checked:shadow-inner group-hover:border-slate-300">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center bg-amber-100 text-amber-600">
                                        <span class="material-symbols-outlined text-[24px]">diversity_3</span>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-slate-700 peer-checked:text-amber-800">Híbrido</p>
                                        <p class="text-xs text-slate-500 peer-checked:text-amber-600">Combina sesiones presenciales y virtuales.</p>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Botones -->
                <div class="mt-10 flex flex-col-reverse sm:flex-row justify-end gap-3 sm:gap-4 border-t border-slate-100 pt-6">
                    <a href="@Url.Action("VerAlumnos")" 
                       class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-6 py-3 text-sm font-bold text-slate-700 shadow-sm transition hover:bg-slate-50 hover:border-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 uppercase tracking-wide">
                        Cancelar
                    </a>
                    <button type="submit" id="btnSubmit"
                            class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-8 py-3 text-sm font-bold text-white shadow transition hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 disabled:opacity-50 uppercase tracking-wide">
                        <span class="material-symbols-outlined mr-2 text-[20px]">how_to_reg</span>
                        Registrar Matrícula
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Personalización ligera para adaptar TomSelect al diseño UI Tailwind Premium */
    .ts-control {
        border-color: #cbd5e1 !important; /* border-slate-300 */
        border-radius: 0.5rem !important; /* rounded-lg */
        padding: 0.75rem 1rem !important; /* py-3 px-4 */
        font-size: 0.875rem !important; /* text-sm */
        font-family: inherit !important;
        box-shadow: none !important;
        background-color: transparent !important;
        transition: all 0.2s !important;
    }
    .ts-control:hover {
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05) !important;
    }
    .ts-control.focus {
        border-color: #6366f1 !important; /* indigo-500 */
        box-shadow: 0 0 0 1px #6366f1 !important; /* ring-1 */
    }
    .ts-dropdown {
        border-radius: 0.5rem !important;
        border: 1px solid #e2e8f0 !important;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1) !important;
        font-size: 0.875rem !important;
        font-family: inherit !important;
        overflow: hidden !important;
        margin-top: 4px !important;
    }
    .ts-dropdown .option {
        padding: 0.6rem 1rem !important;
    }
    .ts-dropdown .active {
        background-color: #eef2ff !important; /* indigo-50 */
        color: #3730a3 !important; /* indigo-800 */
    }
</style>

@section Scripts {
    <!-- TomSelect CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.default.css">
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Inicializar TomSelect Búsqueda Alumno
            new TomSelect("#idAlumno", {
                maxOptions: 200,
                searchField: ['text'],
                placeholder: "Ej: Juan Pérez o juan@email.com...",
                highlight: true,
                render: {
                    option: function(data) {
                        return `<div class="cursor-pointer border-b border-slate-50 py-1"><span class="font-medium text-slate-800">${data.text}</span></div>`;
                    }
                }
            });

            // Inicializar TomSelect Búsqueda Curso
            new TomSelect("#idCurso", {
                placeholder: "Escriba para buscar un curso...",
                maxOptions: 100,
                highlight: true
            });
        });

        // Submit del formulario
        document.getElementById('formModulor').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            if (!this.checkValidity()) {
                this.reportValidity();
                return;
            }
            
            const btn = document.getElementById('btnSubmit');
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = `<div class="h-5 w-5 animate-spin rounded-full border-2 border-white border-t-transparent mr-2"></div> Procesando...`;

            const formData = new FormData(this);

            Swal.fire({
                title: 'Registrando Matrícula',
                text: 'Validando cupos y guardando en base de datos...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            try {
                const response = await fetch('@Url.Action("Modulor", "Matriculas")', {  // Note: ensure correct controller name if needed, Modulor is in what controller? Assuming Matriculas based on view path
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();

                if (data.success) {
                    await Swal.fire({
                        title: '¡Operación Exitosa!',
                        text: data.mensaje || 'Se ha matriculado al estudiante correctamente.',
                        icon: 'success',
                        timer: 2500,
                        showConfirmButton: false,
                        confirmButtonColor: '#4f46e5'
                    });
                    // Redirigir a listado de alumnos o inicio
                    window.location.href = '@Url.Action("VerAlumnos")';
                } else {
                    Swal.fire({
                        title: 'Error detectado',
                        text: data.mensaje || 'No se pudo completar la matrícula',
                        icon: 'error',
                        confirmButtonColor: '#4f46e5'
                    });
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            } catch (err) {
                Swal.fire({
                    title: 'Error de Conexión',
                    text: 'Ocurrió un problema de red al intentar matricular',
                    icon: 'error',
                    confirmButtonColor: '#4f46e5'
                });
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });
    </script>
}