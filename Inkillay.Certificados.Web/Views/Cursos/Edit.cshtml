@model Inkillay.Certificados.Web.Models.Entities.Curso
@{
    ViewData["Title"] = "Editar Curso";
}

<div class="min-h-screen bg-slate-50/50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">

        @if (TempData["Success"] is string successMessage)
        {
            <div class="mb-6 rounded-xl border border-green-200 bg-green-50/80 px-5 py-4 text-sm text-green-800 shadow-sm">
                <div class="flex items-center gap-3">
                    <svg class="h-5 w-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    @successMessage
                </div>
            </div>
        }

        <!-- Card principal -->
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl">
            <!-- Header -->
            <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-8 py-6 text-white">
                <h2 class="text-2xl font-bold tracking-tight">Editar Curso</h2>
                <p class="mt-2 text-indigo-100">Modifica los detalles del curso #@Model.IdCurso</p>
            </div>

            <!-- Formulario -->
            <form asp-action="Edit" method="post" class="p-8">
                <input type="hidden" asp-for="IdCurso" />

                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">

                    <!-- Nombre -->
                    <div class="relative col-span-2">
                        <input asp-for="Nombre" id="nombre" required
                               class="peer block w-full rounded-lg border border-slate-300 bg-transparent px-4 py-3 text-slate-900 placeholder-transparent focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" 
                               placeholder=" " />
                        <label for="nombre"
                               class="absolute left-4 -top-2.5 bg-white px-1 text-sm font-medium text-slate-600 transition-all peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-slate-400 peer-focus:-top-2.5 peer-focus:text-sm peer-focus:text-indigo-600">
                            Nombre del Curso *
                        </label>
                        <span asp-validation-for="Nombre" class="text-xs text-red-600 mt-1 block"></span>
                    </div>

                    <!-- Sumilla / Descripción -->
                    <div class="relative col-span-2">
                        <textarea asp-for="Sumilla" id="sumilla" rows="4"
                                  class="peer block w-full rounded-lg border border-slate-300 bg-transparent px-4 py-3 text-slate-900 placeholder-transparent focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none resize-y"
                                  placeholder=" "></textarea>
                        <label for="sumilla"
                               class="absolute left-4 -top-2.5 bg-white px-1 text-sm font-medium text-slate-600 transition-all peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-slate-400 peer-focus:-top-2.5 peer-focus:text-sm peer-focus:text-indigo-600">
                            Sumilla / Descripción
                        </label>
                    </div>

                    <!-- Costo -->
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-slate-500">S/</div>
                        <input asp-for="Costo" type="number" step="0.01" id="costo"
                               class="peer block w-full rounded-lg border border-slate-300 bg-transparent pl-10 pr-4 py-3 text-slate-900 placeholder-transparent focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" 
                               placeholder=" " />
                        <label for="costo"
                               class="absolute left-10 -top-2.5 bg-white px-1 text-sm font-medium text-slate-600 transition-all peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-slate-400 peer-focus:-top-2.5 peer-focus:text-sm peer-focus:text-indigo-600">
                            Costo *
                        </label>
                    </div>

                    <!-- Imagen URL -->
                    <div class="relative">
                        <input asp-for="Imagen" id="imagenUrl" type="url" placeholder=" "
                               class="peer block w-full rounded-lg border border-slate-300 bg-transparent px-4 py-3 text-slate-900 placeholder-transparent focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                        <label for="imagenUrl"
                               class="absolute left-4 -top-2.5 bg-white px-1 text-sm font-medium text-slate-600 transition-all peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-slate-400 peer-focus:-top-2.5 peer-focus:text-sm peer-focus:text-indigo-600">
                            URL de la Imagen
                        </label>
                    </div>

                    <!-- Previsualización -->
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-2">Previsualización actual</label>
                        <div class="relative overflow-hidden rounded-xl border-2 border-dashed border-slate-300 bg-slate-50/50 p-6 text-center transition-all hover:border-indigo-400">
                            <img id="imagenPreview" src="@Model.Imagen" alt="Previsualización del curso"
                                 class="mx-auto max-h-80 w-full object-contain rounded-lg shadow-inner @(string.IsNullOrWhiteSpace(Model.Imagen) ? "hidden" : "") transition-opacity duration-300" />
                            
                            <div id="imagenPlaceholder" class="flex flex-col items-center justify-center py-10 text-slate-400 @(string.IsNullOrWhiteSpace(Model.Imagen) ? "" : "hidden")">
                                <svg class="h-16 w-16 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                <p class="text-sm">Ingrese una URL válida para previsualizar la imagen</p>
                            </div>

                            <div id="loadingSpinner" class="absolute inset-0 flex items-center justify-center bg-white/60 hidden">
                                <div class="h-8 w-8 animate-spin rounded-full border-4 border-indigo-500 border-t-transparent"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Fechas -->
                    <div class="relative">
                        <input asp-for="FechaInicio" type="date" id="fechaInicio"
                               class="peer block w-full rounded-lg border border-slate-300 bg-transparent px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                        <label for="fechaInicio"
                               class="absolute left-4 -top-2.5 bg-white px-1 text-sm font-medium text-slate-600 transition-all peer-placeholder-shown:top-3 peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-slate-400 peer-focus:-top-2.5 peer-focus:text-sm peer-focus:text-indigo-600">
                            Fecha de Inicio
                        </label>
                    </div>

                    <div class="relative">
                        <input asp-for="FechaFin" type="date" id="fechaFin"
                               class="peer block w-full rounded-lg border border-slate-300 bg-transparent px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                        <label for="fechaFin"
                               class="absolute left-4 -top-2.5 bg-white px-1 text-sm font-medium text-slate-600 transition-all peer-placeholder-shown:top-3 peer-placeholder-shown:text-base peer-placeholder-shown:text-slate-400 peer-focus:-top-2.5 peer-focus:text-sm peer-focus:text-indigo-600">
                            Fecha de Fin
                        </label>
                    </div>
                </div>

                <!-- Botones -->
                <div class="mt-10 flex flex-col sm:flex-row justify-end gap-4">
                    <a asp-action="Details" asp-route-id="@Model.IdCurso" 
                       class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-6 py-3 text-sm font-medium text-slate-700 shadow-sm transition hover:bg-slate-50 hover:border-slate-400">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow transition hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 disabled:opacity-50">
                        <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                        </svg>
                        Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        const input = document.getElementById('imagenUrl');
        const img = document.getElementById('imagenPreview');
        const placeholder = document.getElementById('imagenPlaceholder');
        const spinner = document.getElementById('loadingSpinner');

        function updatePreview() {
            const url = (input.value || '').trim();
            if (!url) {
                img.classList.add('hidden');
                placeholder.classList.remove('hidden');
                img.src = '';
                spinner.classList.add('hidden');
                return;
            }

            spinner.classList.remove('hidden');
            img.src = url;

            img.onload = () => {
                img.classList.remove('hidden');
                placeholder.classList.add('hidden');
                spinner.classList.add('hidden');
            };

            img.onerror = () => {
                img.classList.add('hidden');
                placeholder.classList.remove('hidden');
                spinner.classList.add('hidden');
                placeholder.innerHTML = '<svg class="h-16 w-16 mb-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg><p class="text-sm text-red-600">URL inválida o no accesible</p>';
            };
        }

        input.addEventListener('input', updatePreview);
       
        updatePreview();
    })();
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}