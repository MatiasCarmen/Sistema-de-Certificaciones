@model SIGEC.Certificados.Web.Models.Entities.Curso
@{
    ViewData["Title"] = "Detalles del Curso";
}

<div class="min-h-screen bg-slate-50/50 py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">

        <!-- Mensaje de éxito si viene de edit/create -->
        @if (TempData["Success"] is string successMessage)
        {
            <div class="mb-6 rounded-xl border border-green-200 bg-green-50/80 px-5 py-4 text-sm text-green-800 shadow-sm">
                <div class="flex items-center gap-3">
                    <svg class="h-5 w-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    @successMessage
                </div>
            </div>
        }

        <!-- Header con título y acciones -->
        <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-slate-900">Detalles del Curso</h1>
                <p class="mt-1 text-slate-600">ID: #@Model.IdCurso</p>
            </div>

            <div class="flex flex-wrap gap-3">
                <a asp-action="Edit" asp-route-id="@Model.IdCurso"
                   class="inline-flex items-center gap-2 rounded-lg border border-indigo-200 bg-white px-5 py-2.5 text-sm font-medium text-indigo-700 shadow-sm transition hover:bg-indigo-50 hover:border-indigo-300">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Editar Curso
                </a>

                <a asp-action="Index"
                   class="inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-medium text-slate-700 shadow-sm transition hover:bg-slate-50">
                    Volver al listado
                </a>
            </div>
        </div>

        <!-- Contenido principal: Hero con imagen + info básica -->
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">

                <!-- Imagen grande (izquierda o arriba en mobile) -->
                <div class="lg:col-span-1 bg-slate-50 relative overflow-hidden">
                    @if (!string.IsNullOrWhiteSpace(Model.Imagen))
                    {
                        <img src="@Url.Action("Imagen", "Cursos", new { id = Model.IdCurso })"
                             alt="@Model.Nombre"
                             class="h-full w-full object-cover object-center transition-transform duration-500 hover:scale-105" />
                    }
                    else
                    {
                        <div class="flex h-full items-center justify-center text-slate-300 bg-gradient-to-br from-slate-100 to-slate-200">
                            <div class="text-center">
                                <svg class="mx-auto h-24 w-24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <p class="mt-4 text-lg font-medium">Sin imagen</p>
                            </div>
                        </div>
                    }

                    <!-- Badge de estado superpuesto -->
                    <div class="absolute top-4 right-4">
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-4 py-1.5 text-sm font-semibold shadow backdrop-blur-sm
                            @(Model.EstadoActivo ? "text-green-700 ring-1 ring-green-600/30" : "text-rose-700 ring-1 ring-rose-600/30")">
                            <span class="h-3 w-3 rounded-full @(Model.EstadoActivo ? "bg-green-500" : "bg-rose-500") animate-pulse"></span>
                            @(Model.EstadoActivo ? "Activo" : "Cerrado")
                        </span>
                    </div>
                </div>

                <!-- Info principal (derecha) -->
                <div class="lg:col-span-2 p-8 lg:p-10 flex flex-col gap-8">

                    <div>
                        <h2 class="text-3xl font-bold text-slate-900">@Model.Nombre</h2>
                        <div class="mt-4 flex flex-wrap items-center gap-6 text-sm text-slate-600">
                            <div class="flex items-center gap-2">
                                <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span class="font-semibold text-indigo-700">S/ @Model.Costo.ToString("N2")</span>
                            </div>

                            @if (Model.FechaInicio.HasValue)
                            {
                                <div class="flex items-center gap-2">
                                    <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                    <span>Inicio: @Model.FechaInicio.Value.ToString("dd MMM yyyy")</span>
                                </div>
                            }

                            @if (Model.FechaFin.HasValue)
                            {
                                <div class="flex items-center gap-2">
                                    <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                    <span>Fin: @Model.FechaFin.Value.ToString("dd MMM yyyy")</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Descripción / Sumilla -->
                    <div class="prose prose-slate max-w-none">
                        <h3 class="text-xl font-semibold text-slate-800 mb-3">Descripción / Sumilla</h3>
                        @if (!string.IsNullOrWhiteSpace(Model.Sumilla))
                        {
                            <p class="text-slate-700 whitespace-pre-line">@Model.Sumilla</p>
                        }
                        else
                        {
                            <p class="text-slate-400 italic">No se ha agregado descripción aún.</p>
                        }
                    </div>

                    <!-- Acciones adicionales (opcional: eliminar, activar/desactivar, etc.) -->
                    <div class="mt-auto pt-6 border-t border-slate-100 flex justify-end gap-4">
                        <form asp-action="Delete" asp-route-id="@Model.IdCurso" method="post" class="inline">
                            <button type="submit" onclick="return confirm('¿Realmente deseas eliminar este curso? Esta acción no se puede deshacer.');"
                                    class="inline-flex items-center gap-2 rounded-lg border border-rose-200 bg-white px-5 py-2.5 text-sm font-medium text-rose-700 shadow-sm transition hover:bg-rose-50 hover:border-rose-300">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                Eliminar Curso
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
