@model IEnumerable<Inkillay.Certificados.Web.Models.Entities.Curso>
@{
    ViewData["Title"] = "Gestión de Cursos";
}

<div class="px-4 py-8">
    
    @if (TempData["Success"] is string successMessage)
    {
        <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm text-emerald-800 shadow-sm flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600 text-[20px]">check_circle</span>
            <span class="font-medium">@successMessage</span>
        </div>
    }

    <!-- Encabezado y Acción Principal -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600">menu_book</span>
                Catálogo de Cursos
            </h1>
            <p class="text-sm text-slate-500 mt-1">Administra los programas base que alimentarán tus módulos y certificados.</p>
        </div>
        
        <a asp-action="Create" class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-bold text-white shadow transition hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 uppercase tracking-wide shrink-0">
            <span class="material-symbols-outlined text-[18px]">add_box</span>
            Nuevo Curso
        </a>
    </div>

    <!-- Filtros / Búsqueda (Placeholder) -->
    <div class="bg-white rounded-t-xl border-x border-t border-slate-200 p-4 shadow-sm flex items-center justify-between">
        <div class="relative w-full max-w-sm">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                <span class="material-symbols-outlined text-[18px]">search</span>
            </span>
            <input type="text" placeholder="Buscar curso por nombre..." class="w-full pl-10 pr-4 py-2 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition shadow-sm outline-none">
        </div>
        <div class="text-sm text-slate-500 font-medium hidden sm:block">
            Total: <span class="text-slate-900 font-bold">@Model.Count()</span> programas
        </div>
    </div>

    <!-- Tabla Principal (Gold Standard) -->
    <div class="bg-white shadow-sm border border-slate-200 rounded-b-xl overflow-hidden overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 align-middle text-sm whitespace-nowrap">
            <thead class="bg-slate-50 border-b border-slate-200 hidden sm:table-header-group">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Identificador</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Portada</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Programa / Nombre</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Arancel Base</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Apertura</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Estado Operativo</th>
                    <th scope="col" class="px-6 py-4 text-right font-bold text-slate-500 uppercase tracking-widest text-[10px] rounded-tr-xl">Admins</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center justify-center text-slate-400">
                                <span class="material-symbols-outlined text-6xl mb-3 text-slate-300">import_contacts</span>
                                <p class="text-base font-medium text-slate-600">El catálogo está vacío</p>
                                <p class="text-sm mt-1">Crea el primer curso base para empezar a operar.</p>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr class="hover:bg-indigo-50/40 transition-colors group">
                        
                        <!-- Columna: ID -->
                        <td class="px-6 py-4">
                            <span class="inline-flex font-mono text-xs font-semibold text-slate-500 bg-slate-100 px-2 py-1 rounded">
                                #@item.IdCurso.ToString("D4")
                            </span>
                        </td>
                        
                        <!-- Columna: Imagen -->
                        <td class="px-6 py-4">
                            @if (!string.IsNullOrWhiteSpace(item.Imagen))
                            {
                                <img src="@Url.Action("Imagen", "Cursos", new { id = item.IdCurso })"
                                     alt="@item.Nombre"
                                     class="h-10 w-16 rounded-md object-cover shadow-sm border border-slate-200" />
                            }
                            else
                            {
                                <div class="h-10 w-16 bg-slate-100 rounded-md border border-slate-200 border-dashed flex items-center justify-center text-slate-400" title="Sin portada">
                                    <span class="material-symbols-outlined text-[18px]">hide_image</span>
                                </div>
                            }
                        </td>
                        
                        <!-- Columna: Nombre -->
                        <td class="px-6 py-4">
                            <span class="font-bold text-slate-800">@item.Nombre</span>
                        </td>
                        
                        <!-- Columna: Costo -->
                        <td class="px-6 py-4">
                            <span class="font-medium text-slate-700">
                                S/ @item.Costo.ToString("N2")
                            </span>
                        </td>

                        <!-- Columna: Fecha -->
                        <td class="px-6 py-4 text-slate-600 font-medium">
                            @(item.FechaInicio?.ToString("dd MMM yyyy") ?? "Sin Fecha")
                        </td>

                        <!-- Columna: Estado -->
                        <td class="px-6 py-4">
                            @if (item.EstadoActivo)
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800 border border-emerald-200 shadow-sm">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-sm"></span>
                                    Catálogo
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-slate-100 text-slate-600 border border-slate-200 shadow-sm">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                                    Archivado
                                </span>
                            }
                        </td>

                        <!-- Columna: Acciones -->
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-action="Edit" asp-route-id="@item.IdCurso" class="p-2 text-indigo-600 hover:bg-indigo-100 rounded-lg transition-colors group/btn tooltip" title="Editar Programa">
                                    <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">edit</span>
                                </a>
                                
                                <a asp-action="Details" asp-route-id="@item.IdCurso" class="p-2 text-sky-600 hover:bg-sky-100 rounded-lg transition-colors group/btn tooltip" title="Ver Módulos">
                                    <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">visibility</span>
                                </a>

                                <form asp-action="Delete" asp-route-id="@item.IdCurso" method="post" class="inline m-0 p-0">
                                    <button type="submit" onclick="return confirm('¿Confirmas que deseas retirar este curso del portafolio? Los módulos existentes perderán la referencia visual.');"
                                            class="p-2 text-rose-600 hover:bg-rose-100 rounded-lg transition-colors group/btn tooltip" title="Retirar">
                                        <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">delete</span>
                                    </button>
                                </form>
                            </div>
                            <!-- Móviles -->
                            <div class="flex items-center justify-end sm:hidden">
                                <span class="material-symbols-outlined text-slate-400">more_vert</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
