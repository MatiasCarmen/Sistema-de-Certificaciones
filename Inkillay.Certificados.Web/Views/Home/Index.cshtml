@model IEnumerable<Inkillay.Certificados.Web.Models.RecentActivityViewModel>
@{
    ViewData["Title"] = "Dashboard Principal";
}

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 shadow-sm flex flex-col">
        <h3 class="text-slate-500 text-sm font-medium mb-1">Diplomas Emitidos Hoy</h3>
        <p class="text-3xl font-bold text-slate-800 dark:text-slate-100">145</p>
    </div>
</div>

<div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-200 flex justify-between items-center bg-slate-50/50">
        <h3 class="text-lg font-bold">Actividad Reciente</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-slate-50 dark:bg-slate-800">
                <tr>
                    <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500">ID</th>
                    <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Estudiante</th>
                    <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Curso</th>
                    <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Fecha</th>
                    <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Estado</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 text-sm font-medium text-slate-500">#@item.ID</td>
                        <td class="px-6 py-4 text-sm font-medium text-slate-800 dark:text-slate-100">@item.Estudiante</td>
                        <td class="px-6 py-4 text-sm text-slate-500">@item.Curso</td>
                        <td class="px-6 py-4 text-sm text-slate-500">@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @(item.Estado == "Emitido" ? "bg-emerald-100 text-emerald-800" : "bg-amber-100 text-amber-800")">
                                @item.Estado
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
