@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Centro de Control - Admin";
}

<div class="container-fluid mt-4 mb-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="mb-0">
                <i class="fas fa-chart-line"></i> Centro de Control de Inkillay
            </h2>
            <small class="text-muted">Estadísticas en tiempo real del sistema</small>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-primary h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        <i class="fas fa-users text-primary"></i> Alumnos
                    </h5>
                    <h2 class="text-primary">@Model.TotalAlumnos</h2>
                    <small class="text-muted">Registrados en el sistema</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-success h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        <i class="fas fa-book text-success"></i> Cursos Activos
                    </h5>
                    <h2 class="text-success">@Model.CursosActivos</h2>
                    <small class="text-muted">En ejecución</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-warning h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        <i class="fas fa-dollar-sign text-warning"></i> Recaudación
                    </h5>
                    <h2 class="text-warning">$@Model.RecaudacionTotal.ToString("N2")</h2>
                    <small class="text-muted">Total recaudado</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-info h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">
                        <i class="fas fa-certificate text-info"></i> Certificados
                    </h5>
                    <h2 class="text-info">@Model.CertificadosEmitidos</h2>
                    <small class="text-muted">Emitidos</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráfico de Recaudación -->
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-bar"></i> Recaudación por Mes</h5>
                </div>
                <div class="card-body">
                    <canvas id="graficoRecaudacion" height="80"></canvas>
                </div>
            </div>
        </div>

        <!-- Resumen -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Resumen</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <strong>Total Alumnos:</strong> <span class="badge bg-primary">@Model.TotalAlumnos</span>
                        </li>
                        <li class="mb-3">
                            <strong>Cursos Activos:</strong> <span class="badge bg-success">@Model.CursosActivos</span>
                        </li>
                        <li class="mb-3">
                            <strong>Certificados Emitidos:</strong> <span class="badge bg-info">@Model.CertificadosEmitidos</span>
                        </li>
                        <li>
                            <strong>Recaudación Total:</strong> <span class="badge bg-warning text-dark">$@Model.RecaudacionTotal.ToString("N2")</span>
                        </li>
                    </ul>

                    <hr />

                    <div class="text-muted small">
                        <p>
                            <i class="fas fa-check-circle text-success"></i>
                            Sistema operacional
                        </p>
                        <p>
                            <i class="fas fa-shield-alt text-info"></i>
                            Seguridad: Blindaje Triple Activado
                        </p>
                        <p>
                            <i class="fas fa-database text-primary"></i>
                            Base de datos: Sincronizada
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones Rápidas -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-cogs"></i> Acciones Rápidas</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("Index", "Usuarios")" class="btn btn-primary w-100">
                                <i class="fas fa-users"></i> Gestionar Usuarios
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("Index", "Plantillas")" class="btn btn-success w-100">
                                <i class="fas fa-image"></i> Plantillas
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("Index", "Emision")" class="btn btn-info w-100">
                                <i class="fas fa-certificate"></i> Emisión de Certificados
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("Logout", "Account")" class="btn btn-danger w-100">
                                <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
    // Datos para el gráfico
    const datos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoRecaudacion));
    
    const meses = datos.map(d => d.mes);
    const totales = datos.map(d => d.total);

    const ctx = document.getElementById('graficoRecaudacion').getContext('2d');
    const grafico = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: meses,
            datasets: [{
                label: 'Recaudación ($)',
                data: totales,
                backgroundColor: [
                    'rgba(54, 162, 235, 0.8)',
                    'rgba(75, 192, 192, 0.8)',
                    'rgba(153, 102, 255, 0.8)',
                    'rgba(255, 159, 64, 0.8)',
                    'rgba(255, 99, 132, 0.8)',
                    'rgba(201, 203, 207, 0.8)'
                ],
                borderColor: [
                    'rgba(54, 162, 235, 1)',
                    'rgba(75, 192, 192, 1)',
                    'rgba(153, 102, 255, 1)',
                    'rgba(255, 159, 64, 1)',
                    'rgba(255, 99, 132, 1)',
                    'rgba(201, 203, 207, 1)'
                ],
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: true,
                    position: 'top'
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: function(value) {
                            return '$' + value.toFixed(2);
                        }
                    }
                }
            }
        }
    });
</script>

<style>
    .card {
        border-radius: 8px;
        transition: transform 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important;
    }

    .card-body h2 {
        font-weight: bold;
        margin: 10px 0;
    }

    .badge {
        padding: 8px 12px;
        font-size: 14px;
    }
</style>
