@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Centro de Control";
}

<div class="space-y-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 tracking-tight">Centro de Control</h1>
            <p class="text-sm text-slate-500 mt-1">Visión general y métricas del sistema en tiempo real</p>
        </div>
        <div class="flex items-center gap-3">
            <button class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 text-slate-600 text-sm font-semibold rounded-md hover:bg-slate-50 hover:text-slate-900 transition-all shadow-sm">
                <span class="material-symbols-outlined text-[18px]">download</span>
                <span>Exportar PDF</span>
            </button>
        </div>
    </div>

    <!-- KPIs Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        
        <!-- KPI 1: Alumnos -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200/60 p-5 hover:-translate-y-1 hover:shadow-md transition-all duration-300 group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-[11px] text-slate-500 uppercase font-bold tracking-wider">Alumnos Registrados</p>
                    <h3 class="text-3xl font-black text-slate-800 mt-3 tracking-tight group-hover:text-primary-600 transition-colors">@Model.TotalAlumnos</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center shrink-0 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
                    <span class="material-symbols-outlined text-[26px]">people</span>
                </div>
            </div>
            <div class="mt-4 flex items-center text-[11px] text-slate-500 font-medium">
                <span class="material-symbols-outlined text-[14px] text-blue-500 mr-1">badge</span>
                <span class="font-bold mr-1">@Model.TotalMatriculas</span> matrículas totales
            </div>
        </div>

        <!-- KPI 2: Cursos -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200/60 p-5 hover:-translate-y-1 hover:shadow-md transition-all duration-300 group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-[11px] text-slate-500 uppercase font-bold tracking-wider">Cursos Activos</p>
                    <h3 class="text-3xl font-black text-slate-800 mt-3 tracking-tight group-hover:text-amber-600 transition-colors">@Model.CursosActivos</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-amber-50 text-amber-600 flex items-center justify-center shrink-0 group-hover:bg-amber-500 group-hover:text-white transition-colors duration-300">
                    <span class="material-symbols-outlined text-[26px]">school</span>
                </div>
            </div>
            <div class="mt-4 flex items-center text-[11px] text-slate-500 font-medium">
                <span class="material-symbols-outlined text-[14px] text-amber-500 mr-1">view_module</span>
                <span class="font-bold mr-1">@Model.ModulosActivos</span> módulos activos
            </div>
        </div>

        <!-- KPI 3: Recaudación -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200/60 p-5 hover:-translate-y-1 hover:shadow-md transition-all duration-300 group relative overflow-hidden">
            <!-- Decorative gradient blur -->
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-emerald-50 rounded-full blur-2xl opacity-60 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
            
            <div class="flex items-start justify-between relative">
                <div>
                    <p class="text-[11px] text-slate-500 uppercase font-bold tracking-wider">Recaudación Total</p>
                    <h3 class="text-3xl font-black text-slate-800 mt-3 tracking-tight group-hover:text-emerald-600 transition-colors">
                        <span class="text-[20px] text-slate-400 font-bold mr-0.5">S/</span>@Model.RecaudacionTotal.ToString("N0")
                    </h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0 group-hover:bg-emerald-500 group-hover:text-white transition-colors duration-300">
                    <span class="material-symbols-outlined text-[26px]">payments</span>
                </div>
            </div>
            <div class="mt-4 flex items-center text-[11px] text-slate-500 font-medium relative">
                Acumulado histórico
            </div>
        </div>

        <!-- KPI 4: Certificados -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200/60 p-5 hover:-translate-y-1 hover:shadow-md transition-all duration-300 group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-[11px] text-slate-500 uppercase font-bold tracking-wider">Certifs. Emitidos</p>
                    <h3 class="text-3xl font-black text-slate-800 mt-3 tracking-tight group-hover:text-purple-600 transition-colors">@Model.CertificadosEmitidos</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-purple-50 text-purple-600 flex items-center justify-center shrink-0 group-hover:bg-purple-600 group-hover:text-white transition-colors duration-300">
                    <span class="material-symbols-outlined text-[26px]">workspace_premium</span>
                </div>
            </div>
            <div class="mt-4 flex items-center text-[11px] text-slate-500 font-medium">
                Documentos generados digitalmente
            </div>
        </div>
    </div>

    <!-- Main Content Area: Chart & Summary -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Recaudación Chart -->
        <div class="lg:col-span-2 bg-white border border-slate-200 rounded-xl shadow-sm flex flex-col overflow-hidden hover:shadow-md transition-shadow">
            <div class="p-5 sm:px-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-primary-50 text-primary-600 flex items-center justify-center">
                        <span class="material-symbols-outlined text-[18px]">bar_chart</span>
                    </div>
                    <h3 class="text-sm font-bold text-slate-800 tracking-wide">Evolución de Recaudación</h3>
                </div>
                <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Este Año</span>
            </div>
            <div class="p-5 sm:p-6 flex-1 w-full bg-white relative">
                <canvas id="graficoRecaudacion" class="w-full h-[250px] sm:h-[300px]"></canvas>
            </div>
        </div>

        <!-- Resumen Lateral & Status -->
        <div class="space-y-6 flex flex-col">
            
            <!-- Resumen numérico -->
            <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden flex-1 hover:shadow-md transition-shadow">
                <div class="p-5 border-b border-slate-100 bg-slate-50/50">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center">
                            <span class="material-symbols-outlined text-[18px]">data_usage</span>
                        </div>
                        <h3 class="text-sm font-bold text-slate-800 tracking-wide">Resumen Global</h3>
                    </div>
                </div>
                <div class="p-5">
                    <ul class="space-y-4">
                        <li class="flex items-center justify-between">
                            <div class="flex items-center gap-3 text-sm text-slate-600">
                                <span class="w-2 h-2 rounded-full bg-blue-500"></span>
                                Total Matrículas
                            </div>
                            <span class="font-bold text-slate-800 text-sm">@Model.TotalMatriculas</span>
                        </li>
                        <li class="flex items-center justify-between">
                            <div class="flex items-center gap-3 text-sm text-slate-600">
                                <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                                Cursos Activos
                            </div>
                            <span class="font-bold text-slate-800 text-sm">@Model.CursosActivos</span>
                        </li>
                        <li class="flex items-center justify-between">
                            <div class="flex items-center gap-3 text-sm text-slate-600">
                                <span class="w-2 h-2 rounded-full bg-purple-500"></span>
                                Certificados
                            </div>
                            <span class="font-bold text-slate-800 text-sm">@Model.CertificadosEmitidos</span>
                        </li>
                        <li class="pt-4 mt-2 border-t border-slate-100 flex items-center justify-between">
                            <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">Ingresos Totales</span>
                            <span class="font-black text-emerald-600 text-lg">S/ @Model.RecaudacionTotal.ToString("N0")</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Health Check -->
            <div class="bg-slate-900 rounded-xl shadow-sm border border-slate-800 p-5 relative overflow-hidden">
                <!-- BG Pattern -->
                <div class="absolute -right-4 -top-4 w-32 h-32 bg-primary-500/10 rounded-full blur-2xl"></div>
                
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[16px] text-primary-400">health_and_safety</span>
                    Salud del Sistema
                </h3>
                
                <div class="space-y-3">
                    <div class="flex items-center justify-between bg-white/5 p-2.5 rounded-lg border border-white/10">
                        <span class="text-xs text-slate-300 font-medium">Base de Datos</span>
                        <div class="flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
                            <span class="text-[10px] font-bold text-green-400 uppercase">Conectada</span>
                        </div>
                    </div>
                    <div class="flex items-center justify-between bg-white/5 p-2.5 rounded-lg border border-white/10">
                        <span class="text-xs text-slate-300 font-medium">Seguridad BCrypt</span>
                        <div class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[12px] text-green-400">check_circle</span>
                            <span class="text-[10px] font-bold text-green-400 uppercase">Activa</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tablas: Actividad Reciente -->
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden">
        
        <!-- Table Header -->
        <div class="p-5 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-slate-200 text-slate-700 flex items-center justify-center">
                    <span class="material-symbols-outlined text-[18px]">list_alt</span>
                </div>
                <div>
                    <h3 class="text-sm font-bold text-slate-800">Bitácora de Operaciones</h3>
                    <p class="text-[11px] text-slate-500 font-medium mt-0.5">Últimos movimientos registrados en auditoría</p>
                </div>
            </div>
            <span class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-green-50 text-green-700 text-[10px] font-bold uppercase ring-1 ring-green-600/20 inset shadow-inner">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span> En vivo
            </span>
        </div>

        <!-- Table Content -->
        <div class="overflow-x-auto w-full">
            <table class="w-full text-left text-sm whitespace-nowrap">
                <thead class="bg-white border-b border-slate-100">
                    <tr>
                        <th scope="col" class="px-5 py-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest w-[60%] lg:w-[70%]">Acción / Descripción</th>
                        <th scope="col" class="px-5 py-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest text-right">Tiempo</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-600 bg-white">
                    @if (Model.ActividadReciente.Any())
                    {
                        @foreach (var actividad in Model.ActividadReciente)
                        {
                            <tr class="hover:bg-slate-50/80 transition-colors group">
                                <td class="px-5 py-3.5">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-500 flex items-center justify-center shrink-0 group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors">
                                            <span class="material-symbols-outlined text-[16px]">history</span>
                                        </div>
                                        <div>
                                            <p class="font-bold text-slate-800 text-[13px] group-hover:text-primary-700 transition-colors">@actividad.Accion</p>
                                            <p class="text-[11px] text-slate-500 truncate max-w-xs md:max-w-md lg:max-w-2xl mt-0.5" title="@actividad.Detalles">@actividad.Detalles</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-5 py-3.5 text-right">
                                    <span class="inline-flex items-center px-2 py-1 rounded-md bg-slate-100 text-slate-600 text-[11px] font-semibold">
                                        @actividad.TiempoRelativo
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="px-5 py-12 text-center text-slate-400">
                                <span class="material-symbols-outlined text-4xl mb-2 opacity-50">inbox</span>
                                <p class="text-sm font-medium">No hay operaciones recientes para mostrar.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Table Footer -->
        <div class="px-5 py-3 border-t border-slate-100 bg-slate-50 text-center">
            <a href="#" class="inline-flex items-center gap-1 text-[11px] font-bold text-primary-600 hover:text-primary-800 uppercase tracking-wider transition-colors">
                Ver historial completo
                <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
            </a>
        </div>
    </div>
</div>

<script type="application/json" id="datosRecaudacionVal">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoRecaudacion))
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const datosEl = document.getElementById('datosRecaudacionVal');
        const datos = JSON.parse(datosEl.textContent);

        if (!datos || datos.length === 0) return;

        const meses = datos.map(d => d.mes);
        const totales = datos.map(d => d.total);

        const canvas = document.getElementById('graficoRecaudacion');
        if (!canvas) return;
        
        const ctx = canvas.getContext('2d');
        
        // Create Gradient
        let gradient = ctx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(14, 165, 233, 0.2)');   // blue-500 w/ opacity
        gradient.addColorStop(1, 'rgba(14, 165, 233, 0.0)');   // fade out
        
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: meses,
                datasets: [{
                    label: 'Ingresos',
                    data: totales,
                    borderColor: '#0284c7', // primary-600
                    backgroundColor: gradient,
                    borderWidth: 3,
                    tension: 0.4, // Smooth curve
                    fill: true,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#0284c7',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    pointHoverBackgroundColor: '#0284c7',
                    pointHoverBorderColor: '#ffffff',
                    pointHoverBorderWidth: 3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)', // slate-900
                        titleFont: { family: 'Inter', size: 12, weight: 'bold' },
                        bodyFont: { family: 'Inter', size: 13 },
                        padding: 12,
                        cornerRadius: 8,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return 'S/ ' + context.parsed.y.toLocaleString();
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: '#f1f5f9', // slate-100
                            drawBorder: false,
                            borderDash: [5, 5]
                        },
                        ticks: {
                            callback: function(value) {
                                // Shorten large numbers with k instead of zeros if preferable, but standard is fine
                                return 'S/ ' + value.toLocaleString();
                            },
                            font: { family: 'Inter', size: 11, weight: '500' },
                            color: '#64748b', // slate-500
                            padding: 10
                        },
                        border: {
                            display: false
                        }
                    },
                    x: {
                        grid: {
                            display: false,
                            drawBorder: false
                        },
                        ticks: {
                            font: { family: 'Inter', size: 11, weight: '500' },
                            color: '#64748b',
                            padding: 10
                        },
                        border: {
                            display: false
                        }
                    }
                }
            }
        });
    });
</script>
