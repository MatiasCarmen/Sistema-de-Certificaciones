@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Centro de Control";
}

<div class="space-y-6">
    <!-- Título -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Centro de Control</h1>
            <p class="text-sm text-slate-600 mt-1">Estadísticas del sistema en tiempo real</p>
        </div>
    </div>

    <!-- KPIs Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- KPI 1: Alumnos -->
        <div class="bg-white border border-slate-300 rounded-sm shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-600 uppercase font-bold tracking-wide">Alumnos Registrados</p>
                    <h3 class="text-3xl font-bold text-slate-900 mt-2">@Model.TotalAlumnos</h3>
                    <p class="text-xs text-slate-500 mt-1">Total en el sistema</p>
                </div>
                <span class="material-symbols-outlined text-4xl text-slate-300">people</span>
            </div>
        </div>

        <!-- KPI 2: Cursos -->
        <div class="bg-white border border-slate-300 rounded-sm shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-600 uppercase font-bold tracking-wide">Cursos Activos</p>
                    <h3 class="text-3xl font-bold text-slate-900 mt-2">@Model.CursosActivos</h3>
                    <p class="text-xs text-slate-500 mt-1">En ejecución</p>
                </div>
                <span class="material-symbols-outlined text-4xl text-slate-300">school</span>
            </div>
        </div>

        <!-- KPI 3: Recaudación -->
        <div class="bg-white border border-slate-300 rounded-sm shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-600 uppercase font-bold tracking-wide">Recaudación Total</p>
                    <h3 class="text-3xl font-bold text-slate-900 mt-2">$@Model.RecaudacionTotal.ToString("N0")</h3>
                    <p class="text-xs text-slate-500 mt-1">Acumulado</p>
                </div>
                <span class="material-symbols-outlined text-4xl text-slate-300">trending_up</span>
            </div>
        </div>

        <!-- KPI 4: Certificados -->
        <div class="bg-white border border-slate-300 rounded-sm shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-600 uppercase font-bold tracking-wide">Certificados Emitidos</p>
                    <h3 class="text-3xl font-bold text-slate-900 mt-2">@Model.CertificadosEmitidos</h3>
                    <p class="text-xs text-slate-500 mt-1">Documentos generados</p>
                </div>
                <span class="material-symbols-outlined text-4xl text-slate-300">verified</span>
            </div>
        </div>
    </div>

    <!-- Gráfico de Recaudación -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white border border-slate-300 rounded-sm shadow-sm p-6">
            <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wide mb-4">Recaudación por Mes</h3>
            <canvas id="graficoRecaudacion" height="80"></canvas>
        </div>

        <!-- Resumen Lateral -->
        <div class="bg-white border border-slate-300 rounded-sm shadow-sm p-6">
            <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wide mb-4">Resumen</h3>
            <div class="space-y-3">
                <div class="flex justify-between items-center pb-3 border-b border-slate-200">
                    <span class="text-xs text-slate-600">Total Alumnos</span>
                    <span class="text-sm font-bold text-slate-900">@Model.TotalAlumnos</span>
                </div>
                <div class="flex justify-between items-center pb-3 border-b border-slate-200">
                    <span class="text-xs text-slate-600">Cursos Activos</span>
                    <span class="text-sm font-bold text-slate-900">@Model.CursosActivos</span>
                </div>
                <div class="flex justify-between items-center pb-3 border-b border-slate-200">
                    <span class="text-xs text-slate-600">Certificados</span>
                    <span class="text-sm font-bold text-slate-900">@Model.CertificadosEmitidos</span>
                </div>
                <div class="flex justify-between items-center pt-2">
                    <span class="text-xs text-slate-600">Recaudación</span>
                    <span class="text-sm font-bold text-primary">$@Model.RecaudacionTotal.ToString("N0")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Estado del Sistema -->
    <div class="bg-slate-100 border border-slate-300 rounded-sm p-6">
        <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wide mb-3">Estado del Sistema</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-green-600">check_circle</span>
                <span class="text-xs text-slate-700"><strong>Base de Datos:</strong> Conectada</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-green-600">check_circle</span>
                <span class="text-xs text-slate-700"><strong>Seguridad:</strong> Activada (BCrypt)</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-green-600">check_circle</span>
                <span class="text-xs text-slate-700"><strong>Rate Limiting:</strong> Activo (5/5min)</span>
            </div>
        </div>
    </div>

    <!-- Widget de Actividad Reciente -->
    <div class="bg-white border border-slate-300 rounded-sm shadow-sm flex flex-col">
        <div class="p-3 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
            <h3 class="text-[10px] font-bold text-slate-600 uppercase tracking-widest">Bitácora de Operaciones</h3>
            <span class="text-[9px] bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-bold">VIVO</span>
        </div>
        <div class="flex-1 overflow-auto max-h-64">
            <table class="w-full text-left text-[11px]">
                <tbody class="divide-y divide-slate-100">
                    @if (Model.ActividadReciente.Any())
                    {
                        @foreach (var actividad in Model.ActividadReciente)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="p-3">
                                    <div class="font-bold text-slate-800">@actividad.Accion</div>
                                    <div class="text-slate-400 truncate">@actividad.Detalles</div>
                                </td>
                                <td class="p-3 text-right text-slate-500 whitespace-nowrap">@actividad.TiempoRelativo</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td class="p-4 text-center text-slate-400 col-span-2">Sin movimientos registrados</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="p-2 border-t border-slate-200 bg-slate-50 text-center">
            <a href="#" class="text-[10px] font-bold text-blue-600 hover:underline">VER HISTORIAL COMPLETO</a>
        </div>
    </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
    const datos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoRecaudacion));

    const meses = datos.map(d => d.mes);
    const totales = datos.map(d => d.total);

    const ctx = document.getElementById('graficoRecaudacion').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: meses,
            datasets: [{
                label: 'Recaudación',
                data: totales,
                borderColor: '#0369a1',
                backgroundColor: 'rgba(3, 105, 161, 0.05)',
                borderWidth: 2,
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#0369a1',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(0, 0, 0, 0.05)',
                        drawBorder: false
                    },
                    ticks: {
                        callback: function(value) {
                            return '$' + value.toLocaleString();
                        },
                        font: {
                            size: 11
                        },
                        color: '#6b7280'
                    }
                },
                x: {
                    grid: {
                        display: false,
                        drawBorder: false
                    },
                    ticks: {
                        font: {
                            size: 11
                        },
                        color: '#6b7280'
                    }
                }
            }
        }
    });
</script>
