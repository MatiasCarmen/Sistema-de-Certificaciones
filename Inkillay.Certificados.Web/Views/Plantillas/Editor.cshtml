@model Inkillay.Certificados.Web.Models.Entities.Plantilla
@{
    ViewData["Title"] = "Editor de Plantilla";
}

<div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
    <div class="flex justify-between items-center mb-4 gap-3">
        <h2 class="text-xl font-bold">Ajustar Ubicacion del Nombre</h2>
        <div class="flex items-center gap-3">
            <span id="lblPosicion" class="text-xs text-slate-500 font-semibold uppercase tracking-wide">X: @Model.EjeX, Y: @Model.EjeY</span>
            <button id="btnGuardarEjes" class="bg-primary text-white px-6 py-2 rounded-lg font-bold">
                Guardar Posicion
            </button>
        </div>
    </div>

    <div class="relative inline-block border-2 border-dashed border-slate-300 rounded-lg overflow-hidden select-none" id="canvasDiploma">
        <img src="~/uploads/@Model.RutaImagen" class="max-w-full h-auto" id="imgFondo" alt="@Model.Nombre">

        <div id="nombreMovible"
             style="left: @(Model.EjeX)px; top: @(Model.EjeY)px;"
             class="absolute cursor-move bg-primary/20 border-2 border-primary px-4 py-2 text-primary font-bold whitespace-nowrap rounded">
            NOMBRE DEL ESTUDIANTE
        </div>
    </div>

    <form id="csrfForm" class="hidden">
        @Html.AntiForgeryToken()
    </form>
</div>

@section Scripts {
    <script>
        (() => {
            const canvas = document.getElementById('canvasDiploma');
            const target = document.getElementById('nombreMovible');
            const btnGuardar = document.getElementById('btnGuardarEjes');
            const lblPosicion = document.getElementById('lblPosicion');
            const tokenInput = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]');

            let dragging = false;
            let offsetX = 0;
            let offsetY = 0;

            const getNumeric = (value) => parseInt(String(value).replace('px', ''), 10) || 0;

            function clamp(value, min, max) {
                return Math.max(min, Math.min(value, max));
            }

            function updateLabel() {
                lblPosicion.textContent = `X: ${getNumeric(target.style.left)}, Y: ${getNumeric(target.style.top)}`;
            }

            target.addEventListener('mousedown', (e) => {
                dragging = true;
                const targetRect = target.getBoundingClientRect();
                offsetX = e.clientX - targetRect.left;
                offsetY = e.clientY - targetRect.top;
            });

            document.addEventListener('mouseup', () => {
                dragging = false;
            });

            document.addEventListener('mousemove', (e) => {
                if (!dragging) return;

                const canvasRect = canvas.getBoundingClientRect();
                const maxX = canvas.clientWidth - target.offsetWidth;
                const maxY = canvas.clientHeight - target.offsetHeight;

                const nextX = clamp(e.clientX - canvasRect.left - offsetX, 0, maxX);
                const nextY = clamp(e.clientY - canvasRect.top - offsetY, 0, maxY);

                target.style.left = `${Math.round(nextX)}px`;
                target.style.top = `${Math.round(nextY)}px`;
                updateLabel();
            });

            btnGuardar.addEventListener('click', async () => {
                const x = getNumeric(target.style.left);
                const y = getNumeric(target.style.top);
                const token = tokenInput?.value || '';

                btnGuardar.disabled = true;
                btnGuardar.textContent = 'Guardando...';

                try {
                    const body = new URLSearchParams({
                        id: '@Model.IdPlantilla',
                        x: x.toString(),
                        y: y.toString(),
                        __RequestVerificationToken: token
                    });

                    const response = await fetch('@Url.Action("GuardarEjes", "Plantillas")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                        },
                        body: body.toString()
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('Coordenadas guardadas correctamente.');
                    } else {
                        alert('No se pudo guardar la posicion.');
                    }
                } catch {
                    alert('Error al guardar las coordenadas.');
                } finally {
                    btnGuardar.disabled = false;
                    btnGuardar.textContent = 'Guardar Posicion';
                }
            });
        })();
    </script>
}
