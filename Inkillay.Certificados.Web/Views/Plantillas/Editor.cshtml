@model Inkillay.Certificados.Web.Models.Entities.Plantilla
@{
    ViewData["Title"] = "Editor de Plantilla";
}

<div class="flex flex-col md:flex-row gap-6">
    <div class="w-full md:w-64 bg-white p-4 rounded-xl shadow-sm border border-slate-200 h-fit">
        <h4 class="text-sm font-bold text-primary mb-4 uppercase tracking-wider">Estilo del Texto</h4>

        <div class="space-y-4">
            <div>
                <label class="block text-xs font-medium text-slate-500">Tamano (px)</label>
                <input type="number" id="inputSize" value="@Model.FontSize"
                       class="w-full border-slate-200 rounded-lg text-sm focus:ring-primary">
            </div>
            <div>
                <label class="block text-xs font-medium text-slate-500">Color Hex</label>
                <div class="flex gap-2">
                    <input type="color" id="inputColor" value="@Model.FontColor" class="h-10 w-12 rounded-lg border-none">
                    <input type="text" id="textColor" value="@Model.FontColor" class="w-full border-slate-200 rounded-lg text-sm uppercase">
                </div>
            </div>
        </div>

        <button id="btnGuardarTodo" class="w-full mt-8 bg-primary text-white py-3 rounded-xl font-bold shadow-lg hover:scale-105 transition-transform">
            Guardar Diseno
        </button>
        <form id="csrfEditor" class="hidden">
            @Html.AntiForgeryToken()
        </form>
    </div>

    <div class="relative overflow-auto border-4 border-white shadow-2xl rounded-sm" id="contenedorDiploma">
        <img src="~/uploads/@Model.RutaImagen" id="imgDiploma" class="max-w-full h-auto" alt="@Model.Nombre">
        <div id="nombreMovible"
             data-real-x="@Model.EjeX"
             data-real-y="@Model.EjeY"
             data-real-size="@Model.FontSize"
             style="left: 0px; top: 0px; font-size: 24px; color: @Model.FontColor;"
             class="absolute cursor-move font-bold whitespace-nowrap px-2 outline-dashed outline-1 outline-primary/30">
            MATIAS ADMINISTRADOR
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        (() => {
            const $contenedor = $('#contenedorDiploma');
            const $img = $('#imgDiploma');
            const $movible = $('#nombreMovible');
            const $inputSize = $('#inputSize');
            const $inputColor = $('#inputColor');
            const $textColor = $('#textColor');
            const token = $('#csrfEditor input[name="__RequestVerificationToken"]').val();

            function applyFromRealToView() {
                const img = $img[0];
                if (!img.complete || img.naturalWidth === 0 || img.clientWidth === 0) return;

                const escalaXView = img.clientWidth / img.naturalWidth;
                const escalaYView = img.clientHeight / img.naturalHeight;

                const realX = parseInt($movible.data('real-x'), 10) || 0;
                const realY = parseInt($movible.data('real-y'), 10) || 0;
                const realSize = parseInt($movible.data('real-size'), 10) || 60;

                $movible.css({
                    left: Math.round(realX * escalaXView) + 'px',
                    top: Math.round(realY * escalaYView) + 'px',
                    fontSize: Math.max(8, Math.round(realSize * escalaXView)) + 'px'
                });

                $inputSize.val(parseInt($movible.css('font-size'), 10));
            }

            $inputSize.on('input', function() {
                $movible.css('font-size', ($(this).val() || 1) + 'px');
            });

            $inputColor.on('input', function() {
                const color = $(this).val();
                $movible.css('color', color);
                $textColor.val(color);
            });

            $textColor.on('input', function() {
                let value = ($(this).val() || '').trim();
                if (!value.startsWith('#')) value = '#' + value;
                if (/^#[0-9A-Fa-f]{6}$/.test(value)) {
                    $inputColor.val(value);
                    $movible.css('color', value);
                }
            });

            let dragging = false;
            let startOffsetX = 0;
            let startOffsetY = 0;

            $movible.on('mousedown', function(e) {
                const pos = $movible.position();
                dragging = true;
                startOffsetX = e.pageX - pos.left;
                startOffsetY = e.pageY - pos.top;
                e.preventDefault();
            });

            $(document).on('mousemove', function(e) {
                if (!dragging) return;

                const containerOffset = $contenedor.offset();
                const maxX = $img.width() - $movible.outerWidth();
                const maxY = $img.height() - $movible.outerHeight();

                let x = Math.round(e.pageX - containerOffset.left - startOffsetX);
                let y = Math.round(e.pageY - containerOffset.top - startOffsetY);

                x = Math.max(0, Math.min(maxX, x));
                y = Math.max(0, Math.min(maxY, y));

                $movible.css({ left: x + 'px', top: y + 'px' });
            });

            $(document).on('mouseup', function() {
                dragging = false;
            });

            $('#btnGuardarTodo').click(function() {
                const img = document.getElementById('imgDiploma');
                const nombre = $('#nombreMovible');

                // Calculamos la proporcion: Tamano Real / Tamano en Pantalla
                const escalaX = img.naturalWidth / img.clientWidth;
                const escalaY = img.naturalHeight / img.clientHeight;

                const pos = nombre.position();

                const data = {
                    id: @Model.IdPlantilla,
                    // Traducimos coordenadas de pantalla a pixeles reales de la imagen
                    x: Math.round(pos.left * escalaX),
                    y: Math.round(pos.top * escalaY),
                    // Escalamos tambien el tamano de la letra
                    fontSize: Math.round((parseInt($('#inputSize').val(), 10) || 60) * escalaX),
                    fontColor: $('#inputColor').val(),
                    __RequestVerificationToken: token
                };

                $.post('/Plantillas/ActualizarDiseno', data, function(res) {
                    if (res.success) {
                        alert('Diseno guardado a escala real');
                    } else {
                        alert('Error al guardar el diseno.');
                    }
                }).fail(function() {
                    alert('Error al guardar el diseno.');
                });
            });

            if ($img[0].complete) {
                applyFromRealToView();
            } else {
                $img.on('load', applyFromRealToView);
            }

            $(window).on('resize', applyFromRealToView);
        })();
    </script>
}
