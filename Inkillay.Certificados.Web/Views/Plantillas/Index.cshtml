@model IEnumerable<Inkillay.Certificados.Web.Models.Entities.Plantilla>
@{
    ViewData["Title"] = "Gestión de Plantillas";
}

<div class="bg-white border border-slate-300 shadow-sm rounded-sm">
    <div class="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
        <h3 class="text-xs font-bold uppercase text-slate-600 tracking-wider">Catálogo de Plantillas</h3>
        <a href="@Url.Action("Create")" 
           class="px-3 py-1.5 bg-primary text-white text-xs font-bold rounded-sm hover:bg-sky-800 transition-none flex items-center gap-2">
            <span class="material-symbols-outlined text-base">add</span> Nueva Plantilla
        </a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm border-collapse">
            <thead class="bg-slate-100 border-b border-slate-300 text-slate-700">
                <tr>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">ID</th>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Nombre</th>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Imagen</th>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Estado</th>
                    <th class="px-4 py-2 font-semibold text-xs uppercase text-center">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 text-slate-600">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-2 border-r border-slate-200 font-mono text-xs">#@item.IdPlantilla</td>
                        <td class="px-4 py-2 border-r border-slate-200 font-medium text-slate-800">@item.Nombre</td>
                        <td class="px-4 py-2 border-r border-slate-200">
                            <img src="/uploads/@item.RutaImagen" alt="@item.Nombre" class="h-12 w-auto object-cover rounded-sm border border-slate-200" />
                        </td>
                        <td class="px-4 py-2 border-r border-slate-200">
                            <span class="px-2 py-0.5 text-[10px] font-bold uppercase rounded-sm border @(item.EstadoActivo ? "bg-green-50 text-green-700 border-green-200" : "bg-red-50 text-red-700 border-red-200")">
                                @(item.EstadoActivo ? "Activa" : "Inactiva")
                            </span>
                        </td>
                        <td class="px-4 py-2 text-center">
                            <div class="flex justify-center gap-2">
                                <a href="@Url.Action("Editor", new { id = item.IdPlantilla })" 
                                   class="px-3 py-1 bg-primary text-white text-xs font-bold rounded-sm hover:bg-sky-800 transition-none flex items-center gap-1"
                                   title="Editar diseño">
                                    <span class="material-symbols-outlined text-sm">edit</span> Editor
                                </a>
                                <a href="@Url.Action("Previsualizar", new { id = item.IdPlantilla })" 
                                   target="_blank"
                                   class="px-3 py-1 bg-slate-600 text-white text-xs font-bold rounded-sm hover:bg-slate-800 transition-none flex items-center gap-1"
                                   title="Vista previa">
                                    <span class="material-symbols-outlined text-sm">visibility</span> Preview
                                </a>
                                <form method="post" action="@Url.Action("CambiarEstado")" class="inline-block">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.IdPlantilla" />
                                    <button type="submit" 
                                            onclick="return confirm('¿Cambiar el estado de esta plantilla?');"
                                            class="px-3 py-1 text-xs font-bold rounded-sm border transition-none @(item.EstadoActivo ? "bg-red-50 text-red-700 border-red-200 hover:bg-red-100" : "bg-green-50 text-green-700 border-green-200 hover:bg-green-100")">
                                        @(item.EstadoActivo ? "Desactivar" : "Activar")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="p-8 text-center text-slate-500">
                <span class="material-symbols-outlined text-4xl mb-2 block">inbox</span>
                <p class="text-sm">No hay plantillas registradas</p>
                <a href="@Url.Action("Create")" class="text-primary hover:underline text-xs font-bold mt-2 inline-block">
                    Crear la primera plantilla
                </a>
            </div>
        }
    </div>
</div>