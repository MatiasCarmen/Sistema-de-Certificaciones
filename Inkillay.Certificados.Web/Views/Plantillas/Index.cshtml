@model IEnumerable<Inkillay.Certificados.Web.Models.Entities.Plantilla>
@{
    ViewData["Title"] = "Catalogo de Plantillas";
}

<main class="max-w-7xl mx-auto">
    <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8 pb-4 border-b border-slate-300">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Catálogo de Plantillas</h1>
            <p class="text-sm text-slate-600 mt-1">Gestiona las plantillas de certificados del sistema.</p>
        </div>
        <button onclick="document.getElementById('modalPlantilla').showModal()"
                class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-white text-sm font-bold rounded-sm hover:bg-sky-800">
            <span class="material-symbols-outlined text-base">add</span>
            Nueva Plantilla
        </button>
    </header>

    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var item in Model)
        {
            <article class="flex flex-col bg-white border border-slate-300 rounded-sm shadow-sm @(item.Estado ? "" : "opacity-60")">
                <div class="aspect-[4/3] bg-slate-100 overflow-hidden flex items-center justify-center p-3 border-b border-slate-200">
                    <img src="~/uploads/@item.RutaImagen" alt="@item.Nombre"
                         class="w-full h-full object-contain">
                </div>

                <div class="p-4 flex flex-col flex-1">
                    <h3 class="text-slate-900 font-bold text-sm mb-3 line-clamp-2" title="@item.Nombre">
                        @item.Nombre
                    </h3>

                    <div class="mt-auto pt-3 border-t border-slate-200 flex gap-2">
                        <a href="@Url.Action("Previsualizar", "Plantillas", new { id = item.IdPlantilla })" target="_blank"
                           class="flex-1 px-2 py-1.5 bg-slate-100 text-slate-700 hover:bg-slate-200 text-xs font-bold rounded-sm text-center">
                            Vista Previa
                        </a>
                        <a href="@Url.Action("Editor", "Plantillas", new { id = item.IdPlantilla })"
                           class="flex-1 px-2 py-1.5 bg-primary text-white hover:bg-sky-800 text-xs font-bold rounded-sm text-center">
                            Editar
                        </a>
                    </div>

                    <div class="mt-3 pt-3 border-t border-slate-200 flex items-center justify-between">
                        <span class="text-xs font-semibold text-slate-600">Estado</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" @(item.Estado ? "checked" : "") class="sr-only peer"
                                   onchange="cambiarEstado(@item.IdPlantilla, this)">
                            <div class="w-10 h-5 bg-slate-300 peer-checked:bg-primary rounded-sm peer-focus:ring-2 peer-focus:ring-primary after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:w-4 after:h-4 after:rounded-sm after:transition-all peer-checked:after:translate-x-5">
                            </div>
                            <span class="ml-2 text-xs font-bold @(item.Estado ? "text-green-700" : "text-red-700")">
                                @(item.Estado ? "Activo" : "Inactivo")
                            </span>
                        </label>
                    </div>
                </div>
            </article>
        }
    </section>
</main>

                <dialog id="modalPlantilla"
                        class="rounded-2xl shadow-2xl p-0 w-full max-w-md bg-white dark:bg-slate-900 overflow-hidden border border-slate-200 dark:border-slate-700 backdrop:bg-slate-900/60 backdrop:backdrop-blur-sm">
                    <div
                        class="bg-slate-50 dark:bg-slate-800/50 px-6 py-4 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between">
                        <div class="flex items-center gap-3 text-primary">
                            <span class="material-symbols-outlined bg-primary/10 p-1.5 rounded-lg">upload_file</span>
                            <h3 class="text-lg font-bold text-slate-900 dark:text-white">Nueva Plantilla</h3>
                        </div>
                        <button type="button" onclick="document.getElementById('modalPlantilla').close()"
                                class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>

                    <form id="formPlantilla" asp-controller="Plantillas" asp-action="Crear" method="post" enctype="multipart/form-data"
                          class="p-6 space-y-5">
                        @Html.AntiForgeryToken()
                        <div>
                            <label for="nombrePlantilla"
                                   class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Nombre Descriptivo</label>
                            <input type="text" id="nombrePlantilla" name="nombre" required placeholder="Ej. Diploma Excel Avanzado"
                                   class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-900 dark:text-white placeholder-slate-400 focus:bg-white dark:focus:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Archivo de
                                Imagen</label>
                                <div
                                    class="relative w-full border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-xl p-4 text-center hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:border-primary transition-colors cursor-pointer group">
                                    <input type="file" name="imagen" accept="image/*" required
                                           class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
                                    <span
                                    class="material-symbols-outlined text-slate-400 group-hover:text-primary mb-2 block text-3xl">cloud_upload</span>
                                    <p class="text-sm text-slate-600 dark:text-slate-400 font-medium">Arrastra tu imagen o <span
                                        class="text-primary font-semibold">haz clic para explorar</span></p>
                                        <p class="text-xs text-slate-400 mt-1">PNG, JPG hasta 5MB</p>
                                    </div>
                                </div>

                                <div class="flex justify-end gap-3 pt-4 border-t border-slate-100 dark:border-slate-700 mt-6">
                                    <button type="button" onclick="document.getElementById('modalPlantilla').close()"
                                            class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                                        Cancelar
                                    </button>
                                    <button type="submit" id="btnGuardarPlantilla"
                                            class="px-5 py-2.5 bg-primary text-white text-sm font-semibold rounded-lg shadow-sm hover:bg-primary/90 hover:shadow transition-all focus:ring-2 focus:ring-primary focus:ring-offset-2">
                                        Guardar Plantilla
                                    </button>
                                </div>
                            </form>
                        </dialog>

                        @section Scripts {
                            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
                            <script>
                                $('#formPlantilla').on('submit', function (e) {
                                e.preventDefault();
                                const formData = new FormData(this);
                                const $btn = $('#btnGuardarPlantilla');
                                $btn.prop('disabled', true).text('Procesando...');

                                $.ajax({
                                url: '@Url.Action("Crear", "Plantillas")',
                                type: 'POST',
                                data: formData,
                                contentType: false,
                                processData: false,
                                success: function (res) {
                                if (res.success) {
                                location.reload();
                                } else {
                                alert(res.mensaje || 'No se pudo guardar la plantilla.');
                                $btn.prop('disabled', false).text('Guardar Plantilla');
                                }
                                },
                                error: function () {
                                alert('Error al conectar con el servidor.');
                                $btn.prop('disabled', false).text('Guardar Plantilla');
                                }
                                });
                                });

                                function cambiarEstado(id, el) {
                                const token = $('#formPlantilla input[name="__RequestVerificationToken"]').val();
                                const $label = $(el).closest('label').find('.estado-texto');
                                const valorOriginal = !el.checked;

                                $.post('@Url.Action("CambiarEstado", "Plantillas")', {
                                id: id,
                                __RequestVerificationToken: token
                                }, function (res) {
                                if (res.success) {
                                if (el.checked) {
                                $label.text('Activo').removeClass('text-slate-500 dark:text-slate-400').addClass('text-primary');
                                } else {
                                $label.text('Inactivo').removeClass('text-primary').addClass('text-slate-500 dark:text-slate-400');
                                }
                                } else {
                                el.checked = valorOriginal;
                                alert('No se pudo cambiar el estado.');
                                }
                                }).fail(function () {
                                el.checked = valorOriginal;
                                alert('No se pudo cambiar el estado.');
                                });
                                }
                            </script>
                        }