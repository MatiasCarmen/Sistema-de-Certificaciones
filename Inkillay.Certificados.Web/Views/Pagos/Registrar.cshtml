@{
    ViewData["Title"] = "Registrar Pago";
}

<div class="px-4 py-8 max-w-3xl mx-auto">
    
    <!-- Encabezado Corto -->
    <div class="mb-8 flex items-center gap-4">
        <a href="@Url.Action("Index", "Docentes")" class="w-10 h-10 bg-white border border-slate-200 text-slate-600 rounded-xl justify-center items-center flex hover:bg-slate-50 transition-colors shadow-sm">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-800">Caja y Tesorería</h1>
            <p class="text-sm text-slate-500 mt-1">Registra y valida un abono para la matrícula seleccionada.</p>
        </div>
    </div>

    <!-- Formulario Gold Standard -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="h-2 bg-gradient-to-r from-emerald-500 to-emerald-400"></div>
        
        <form id="formPago" class="p-6 sm:p-8 space-y-6">
            @Html.AntiForgeryToken()

            <!-- Info Bloqueada -->
            <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 flex items-center gap-4">
                <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-lg flex items-center justify-center font-bold font-mono border border-indigo-200">
                    #@ViewBag.IdModulo
                </div>
                <div>
                    <h4 class="text-xs font-bold text-slate-500 uppercase tracking-widest">Expediente de Matrícula</h4>
                    <p class="text-sm font-medium text-slate-700 mt-0.5">Operación a registrar en este código</p>
                </div>
                <input type="hidden" name="IdModulo" id="idModulo" value="@ViewBag.IdModulo" />
            </div>

            <!-- Inputs Financieros -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Monto -->
                <div class="relative">
                    <input type="number" step="0.01" name="Monto" id="monto" required
                           class="peer w-full h-14 px-4 pt-4 pb-1 rounded-xl border border-slate-300 bg-white text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition-all placeholder-transparent font-medium"
                           placeholder="0.00" />
                    <label for="monto" class="absolute left-4 top-1 text-[10px] font-bold uppercase tracking-wider text-slate-400 transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:top-4 peer-placeholder-shown:normal-case peer-placeholder-shown:font-medium peer-focus:top-1 peer-focus:text-[10px] peer-focus:font-bold peer-focus:uppercase peer-focus:text-emerald-600 cursor-text">
                        Monto a Abonar (S/) *
                    </label>
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 text-emerald-600 pointer-events-none font-bold">
                        <span class="material-symbols-outlined text-[20px]">payments</span>
                    </div>
                </div>

                <!-- Forma de Pago -->
                <div class="space-y-1.5">
                    <label for="formaPago" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider ml-1">Forma de Pago *</label>
                    <select name="formaPago" id="formaPago" class="w-full h-12 px-4 rounded-xl border border-slate-300 bg-white text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all shadow-sm">
                        <option value="Efectivo">Billetes / Efectivo Físico</option>
                        <option value="Yape">Yape</option>
                        <option value="Plin">Plin</option>
                        <option value="Transferencia BCP">Transferencia BCP</option>
                        <option value="Transferencia Interbank">Transferencia Interbank</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Tipo Pago -->
                <div class="space-y-1.5">
                    <label for="tipoPago" class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider ml-1">Modalidad de Cuota *</label>
                    <select name="tipoPago" id="tipoPago" class="w-full h-12 px-4 rounded-xl border border-slate-300 bg-white text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all shadow-sm">
                        <option value="Contado">Pago al Contado (Total)</option>
                        <option value="Parcial">Abono Parcial</option>
                    </select>
                </div>

                <!-- Referencia -->
                <div class="relative mt-[22px]">
                    <input type="text" name="Referencia" id="referencia" required
                           class="peer w-full h-12 px-4 pt-4 pb-1 rounded-xl border border-slate-300 bg-white text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition-all placeholder-transparent font-medium"
                           placeholder="Ej: Número de operación" />
                    <label for="referencia" class="absolute left-4 top-1 text-[10px] font-bold uppercase tracking-wider text-slate-400 transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:top-3.5 peer-placeholder-shown:normal-case peer-placeholder-shown:font-medium peer-focus:top-1 peer-focus:text-[10px] peer-focus:font-bold peer-focus:uppercase peer-focus:text-emerald-600 cursor-text">
                        Referencia / Obs. *
                    </label>
                </div>
            </div>

            <!-- Submit Section -->
            <div class="pt-6 border-t border-slate-100 flex flex-col sm:flex-row gap-3">
                <button type="button" onclick="confirmarPago()" id="btnSubmit"
                        class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-700 focus:ring-4 focus:ring-emerald-500/20 active:scale-[0.98] transition-all shadow-md">
                    <span class="material-symbols-outlined text-[20px]">add_task</span>
                    Validar y Registrar Pago
                </button>
                <a href="@Url.Action("Index", "Docentes")" 
                   class="sm:w-32 inline-flex items-center justify-center px-6 py-3.5 bg-white border border-slate-300 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmarPago() {
            // Validacion frontend super basica
            const monto = $('#monto').val();
            const ref = $('#referencia').val();
            
            if(!monto || monto <= 0 || !ref) {
                Swal.fire({
                    title: 'Formulario Incompleto',
                    text: 'Asegúrate de colocar un monto válido y la referencia bancaria.',
                    icon: 'warning',
                    confirmButtonColor: '#10b981',
                    customClass: { popup: 'rounded-2xl shadow-xl border border-slate-200', confirmButton: 'rounded-lg px-6 py-2.5 font-bold' }
                });
                return;
            }

            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined inline animate-spin text-[20px]">autorenew</span> Procesando...';

            const data = {
                idModulo: $('#idModulo').val(),
                monto: monto,
                referencia: ref,
                formaPago: $('#formaPago').val(),
                tipoPago: $('#tipoPago').val(),
                __RequestVerificationToken: $('#formPago input[name="__RequestVerificationToken"]').val()
            };

            $.post('/Pagos/Registrar', data, function(res) {
                if (res.success) {
                    Swal.fire({
                        title: 'Abono Registrado',
                        text: 'El pago ha impactado correctamente la cuenta del alumno.',
                        icon: 'success',
                        confirmButtonColor: '#10b981',
                        customClass: { popup: 'rounded-2xl shadow-xl', confirmButton: 'rounded-lg px-6 py-2.5 font-bold' }
                    }).then(() => { window.location.href = '/Docentes/Index'; });
                } else {
                    Swal.fire('Error Operativo', res.message || 'No se pudo liquidar la transacción.', 'error');
                    btn.disabled = false;
                    btn.innerHTML = '<span class="material-symbols-outlined text-[20px]">add_task</span> Validar y Registrar Pago';
                }
            }).fail(function() {
                Swal.fire('Error de Red', 'Fallo de conectividad con servidores Inkillay.', 'error');
                btn.disabled = false;
                btn.innerHTML = '<span class="material-symbols-outlined text-[20px]">add_task</span> Validar y Registrar Pago';
            });
        }
    </script>
}
