@{
    ViewData["Title"] = "Registrar Pago";
}

<div class="max-w-2xl mx-auto bg-white border border-slate-300 rounded-sm shadow-sm">
    <div class="p-6 border-b border-slate-300 bg-slate-50">
        <h2 class="text-base font-bold uppercase text-slate-700 tracking-tight">Registro de Pago</h2>
        <p class="text-xs text-slate-500 mt-1">Ingresa los datos del pago de la matrícula del alumno</p>
    </div>

    <form id="formPago" class="p-6 space-y-5">
        @Html.AntiForgeryToken()

        <div class="space-y-2">
            <label class="block text-xs font-bold uppercase text-slate-600 tracking-wider">ID de Matrícula</label>
            <input type="number" name="IdMatricula" id="idMatricula" value="@ViewBag.IdMatricula"
                   class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm text-slate-900 bg-slate-50 focus:ring-1 focus:ring-primary focus:border-primary" 
                   readonly />
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
                <label class="block text-xs font-bold uppercase text-slate-600 tracking-wider">Monto a Abonar (S/)</label>
                <input type="number" step="0.01" name="Monto" id="monto" required
                       class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm text-slate-900 focus:ring-1 focus:ring-primary focus:border-primary" 
                       placeholder="0.00" />
            </div>

            <div class="space-y-2">
                <label class="block text-xs font-bold uppercase text-slate-600 tracking-wider">Forma de Pago</label>
                <select name="formaPago" id="formaPago" class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm text-slate-900 focus:ring-1 focus:ring-primary focus:border-primary">
                    <option value="Efectivo">Efectivo</option>
                    <option value="Yape">Yape</option>
                    <option value="Plin">Plin</option>
                    <option value="Transferencia BCP">Transferencia BCP</option>
                    <option value="Transferencia Interbank">Transferencia Interbank</option>
                </select>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
                <label class="block text-xs font-bold uppercase text-slate-600 tracking-wider">Tipo de Pago</label>
                <select name="tipoPago" id="tipoPago" class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm text-slate-900 focus:ring-1 focus:ring-primary focus:border-primary">
                    <option value="Contado">Contado</option>
                    <option value="Parcial">Parcial</option>
                </select>
            </div>
            <div class="space-y-2">
                <label class="block text-xs font-bold uppercase text-slate-600 tracking-wider">Referencia / Observación</label>
                <input type="text" name="Referencia" id="referencia" required
                       class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm text-slate-900 focus:ring-1 focus:ring-primary focus:border-primary" 
                       placeholder="Ej: Número de operación, referencia bancaria" />
            </div>
        </div>

        <div class="pt-4 border-t border-slate-300 flex gap-3">
            <button type="button" onclick="confirmarPago()"
                    class="flex-1 px-4 py-2 bg-primary text-white text-xs font-bold uppercase rounded-sm hover:bg-sky-800 transition-colors">
                Confirmar Pago
            </button>
            <a href="@Url.Action("Index", "Docentes")" 
               class="flex-1 px-4 py-2 bg-slate-200 text-slate-700 text-xs font-bold uppercase rounded-sm hover:bg-slate-300 text-center">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmarPago() {
            const data = {
                idMatricula: $('#idMatricula').val(),
                monto: $('#monto').val(),
                referencia: $('#referencia').val(),
                formaPago: $('#formaPago').val(),
                tipoPago: $('#tipoPago').val(),
                __RequestVerificationToken: $('#formPago input[name="__RequestVerificationToken"]').val()
            };

            $.post('/Pagos/Registrar', data, function(res) {
                if (res.success) {
                    Swal.fire('Éxito', 'El pago ha sido registrado correctamente.', 'success')
                        .then(() => { window.location.href = '/Docentes/Index'; });
                } else {
                    Swal.fire('Error', res.message || 'No se pudo registrar el pago.', 'error');
                }
            }).fail(function() {
                Swal.fire('Error', 'No se pudo registrar el pago.', 'error');
            });
        }
    </script>
}
