@model IEnumerable<Inkillay.Certificados.Web.Models.Entities.Modulo>
@{
    ViewData["Title"] = "Alumnos del Curso";
}

<div class="bg-white border border-slate-300 rounded-sm shadow-sm">
    <div class="p-4 border-b border-slate-300 bg-slate-50 flex justify-between items-center">
        <div>
            <h3 class="text-xs font-bold uppercase text-slate-600 tracking-wider">Alumnos Modulodos</h3>
            <p class="text-xs text-slate-500 mt-1">@ViewData["NombreCurso"]</p>
        </div>
        <a href="@Url.Action("Modulor")"
           class="px-3 py-1.5 bg-primary text-white text-xs font-bold rounded-sm hover:bg-sky-800 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">person_add</span> Modulor Alumno
        </a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm border-collapse">
            <thead class="bg-slate-100 border-b border-slate-300 text-slate-700">
                <tr>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">ID</th>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Alumno</th>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Fecha Matrícula</th>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Aprobado</th>
                    <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Pagado</th>
                    <th class="px-4 py-2 text-center font-semibold text-xs uppercase">Certificado</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 text-slate-600">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-4 py-6 text-sm text-slate-500 text-center">
                            No hay alumnos Modulodos en este curso.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-2 border-r border-slate-200 font-mono text-xs">#@item.IdModulo</td>
                            <td class="px-4 py-2 border-r border-slate-200 font-medium text-slate-800">@item.NombreAlumno</td>
                            <td class="px-4 py-2 border-r border-slate-200">@item.FechaModulo.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-2 border-r border-slate-200">
                                <span class="text-xs font-bold @(item.Aprobado ? "text-green-700" : "text-red-700")">
                                    @(item.Aprobado ? "SÍ" : "NO")
                                </span>
                            </td>
                            <td class="px-4 py-2 border-r border-slate-200">
                                <span class="text-xs font-bold @(item.TotalPagado >= item.CostoCurso ? "text-green-700" : "text-amber-600")">
                                    S/ @item.TotalPagado.ToString("N2") / S/ @item.CostoCurso.ToString("N2")
                                </span>
                            </td>
                            <td class="px-4 py-2 text-center">
                                @if (item.Aprobado && item.TotalPagado >= item.CostoCurso)
                                {
                                    <a href="@Url.Action("DescargarPdf", "Emision", new { idModulo = item.IdModulo })"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary hover:bg-sky-800 text-white text-xs font-bold rounded-sm transition-colors">
                                        <span class="material-symbols-outlined text-sm">download</span> PDF
                                    </a>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-slate-100 text-slate-400 text-xs font-bold rounded-sm">Pendiente</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="p-3 border-t border-slate-200 bg-slate-50">
        <a href="@Url.Action("Index")" class="text-xs text-primary font-bold hover:underline">← Volver al Panel Docente</a>
    </div>
</div>
