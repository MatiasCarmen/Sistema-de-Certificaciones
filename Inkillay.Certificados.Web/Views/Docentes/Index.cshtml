@model IEnumerable<Inkillay.Certificados.Web.Models.ViewModels.ReporteCursoViewModel>
@{
    ViewData["Title"] = "Panel del Docente";
}

<div class="px-4 py-8">
    
    <!-- Encabezado y Acción Principal -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600">dashboard</span>
                Panel del Docente
            </h1>
            <p class="text-sm text-slate-500 mt-1">Gestiona tus cursos, alumnos y emisiones de certificados académicos.</p>
        </div>
        
        <div class="flex items-center gap-3 shrink-0">
            <a asp-action="Modulor" class="inline-flex items-center justify-center gap-2 rounded-lg bg-white border border-slate-300 px-5 py-2.5 text-sm font-bold text-slate-700 shadow-sm transition hover:bg-slate-50 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 uppercase tracking-wide">
                <span class="material-symbols-outlined text-[18px]">how_to_reg</span>
                Matrícula
            </a>
            
            <a asp-controller="Usuarios" asp-action="Create" class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-bold text-white shadow transition hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 uppercase tracking-wide">
                <span class="material-symbols-outlined text-[18px]">person_add</span>
                Nuevo Alumno
            </a>
        </div>
    </div>

    <!-- KPIs -->
    @if (Model.Any())
    {
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 mb-8">
            @foreach (var curso in Model)
            {
                <div class="group relative overflow-hidden rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:shadow-md hover:border-indigo-200 flex flex-col">
                    <div class="flex items-start justify-between mb-4">
                        <div class="pr-4">
                            <h4 class="text-[11px] font-bold uppercase tracking-wider text-slate-400 line-clamp-1">@curso.NombreCurso</h4>
                            <p class="mt-2 text-3xl font-black text-slate-800">@curso.TotalModulodos</p>
                            <p class="text-[10px] text-slate-500 font-medium uppercase tracking-wide mt-1">Alumnos Inscritos</p>
                        </div>
                        <div class="rounded-lg bg-indigo-50 p-2.5 text-indigo-600 border border-indigo-100 flex-shrink-0">
                            <span class="material-symbols-outlined text-[24px]">school</span>
                        </div>
                    </div>

                    <div class="mt-auto pt-4 border-t border-slate-100 flex flex-col gap-2">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-1.5 text-[11px] font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded">
                                <span class="material-symbols-outlined text-[14px]">check_circle</span>
                                @curso.TotalPagados Al día
                            </div>
                            <div class="flex items-center gap-1.5 text-[11px] font-bold text-amber-600 bg-amber-50 px-2 py-1 rounded">
                                <span class="material-symbols-outlined text-[14px]">pending_actions</span>
                                @(curso.TotalModulodos - curso.TotalPagados) Pendientes
                            </div>
                        </div>
                        <div class="text-[11px] text-slate-500 font-medium text-center bg-slate-50 py-1 rounded border border-slate-100">
                            <span class="font-bold text-indigo-600">@curso.TotalDescargas</span> Certificados Emitidos
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Encabezado de la Tabla -->
    <div class="bg-white rounded-t-xl border-x border-t border-slate-200 p-4 shadow-sm flex flex-col sm:flex-row items-center justify-between gap-4">
        <h3 class="text-sm font-bold uppercase tracking-wider text-slate-600 m-0">Mis Cursos Asignados</h3>
        
        @if (Model.Any())
        {
            <div class="relative w-full max-w-sm">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                    <span class="material-symbols-outlined text-[18px]">search</span>
                </span>
                <input id="searchInput" type="text" placeholder="Filtrar cursos asignados..." class="w-full pl-10 pr-4 py-2 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition shadow-sm outline-none">
                <button id="clearSearch" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-slate-600 hidden">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>
            </div>
        }
    </div>

    <!-- Tabla Principal (Gold Standard) -->
    <div class="bg-white shadow-sm border border-slate-200 rounded-b-xl overflow-hidden overflow-x-auto">
        <table id="cursosTable" class="min-w-full divide-y divide-slate-200 align-middle text-sm whitespace-nowrap">
            <thead class="bg-slate-50 border-b border-slate-200 hidden sm:table-header-group">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Programa Acreditado</th>
                    <th scope="col" class="px-6 py-4 text-center font-bold text-slate-500 uppercase tracking-widest text-[10px]">Volumen (Inscritos)</th>
                    <th scope="col" class="px-6 py-4 text-center font-bold text-slate-500 uppercase tracking-widest text-[10px]">Estado Financiero (Al día / Pendientes)</th>
                    <th scope="col" class="px-6 py-4 text-right font-bold text-slate-500 uppercase tracking-widest text-[10px] rounded-tr-xl">Herramientas Docentes</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center justify-center text-slate-400">
                                <span class="material-symbols-outlined text-6xl mb-3 text-slate-300">class</span>
                                <p class="text-base font-medium text-slate-600">No tienes cursos asignados aún</p>
                                <p class="text-sm mt-1">Contacta al administrador o espera a ser asignado a un curso.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-indigo-50/40 transition-colors group curso-row" data-search="@item.NombreCurso.ToLower()">
                            
                            <!-- Columna: Curso -->
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center flex-shrink-0 border border-indigo-200 shadow-sm">
                                        <span class="material-symbols-outlined text-[16px]">menu_book</span>
                                    </div>
                                    <span class="font-bold text-slate-800 text-sm">@item.NombreCurso</span>
                                </div>
                            </td>
                            
                            <!-- Columna: Inscritos -->
                            <td class="px-6 py-4 text-center">
                                <span class="inline-flex items-center justify-center min-w-[32px] font-bold text-indigo-700 bg-indigo-50 border border-indigo-100 rounded px-2 py-1 shadow-sm">
                                    @item.TotalModulodos
                                </span>
                            </td>
                            
                            <!-- Columna: Estado Financiero -->
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-center gap-1.5">
                                    <span class="inline-flex items-center rounded bg-emerald-50 px-2 py-1 text-xs font-bold text-emerald-700 border border-emerald-200 shadow-sm tooltip" title="Al día">
                                        <span class="material-symbols-outlined text-[14px] mr-1">paid</span>
                                        @item.TotalPagados
                                    </span>
                                    <span class="text-slate-300 font-bold">/</span>
                                    <span class="inline-flex items-center rounded bg-amber-50 px-2 py-1 text-xs font-bold text-amber-700 border border-amber-200 shadow-sm tooltip" title="Pendientes de pago">
                                        <span class="material-symbols-outlined text-[14px] mr-1">money_off</span>
                                        @(item.TotalModulodos - item.TotalPagados)
                                    </span>
                                </div>
                            </td>

                            <!-- Columna: Acciones -->
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-1 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                                    
                                    <a asp-action="VerAlumnos" asp-route-idCurso="@item.IdCurso" class="p-2 text-indigo-600 hover:bg-indigo-100 rounded-lg transition-colors group/btn tooltip" title="Ver Alumnos">
                                        <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">groups</span>
                                    </a>

                                    <a asp-controller="Emision" asp-action="Index" asp-route-idCurso="@item.IdCurso" class="p-2 text-sky-600 hover:bg-sky-100 rounded-lg transition-colors group/btn tooltip" title="Emitir Certificados">
                                        <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">workspace_premium</span>
                                    </a>

                                    <a asp-controller="Pagos" asp-action="Registrar" asp-route-idModulo="@item.IdModulo" class="p-2 text-emerald-600 hover:bg-emerald-100 rounded-lg transition-colors group/btn tooltip" title="Registrar Pagos">
                                        <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">point_of_sale</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <!-- Mensaje no found -->
        <div id="noResults" class="hidden px-6 py-12 text-center border-t border-slate-100">
            <div class="flex flex-col items-center justify-center text-slate-400">
                <span class="material-symbols-outlined text-4xl mb-2 text-slate-300">search_off</span>
                <p class="text-sm font-medium text-slate-500">No se encontraron cursos que coincidan con la búsqueda.</p>
                <button id="clearAll" class="mt-2 text-indigo-600 hover:text-indigo-800 font-bold text-xs uppercase tracking-wide">Deshacer Filtro</button>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="bg-slate-50 border-t border-slate-200 px-6 py-4 flex items-center justify-between">
                <span class="text-xs font-medium text-slate-500 uppercase tracking-widest">
                    Asignaciones Visualizadas: <span id="count" class="font-bold text-slate-900 text-sm ml-1">@Model.Count()</span>
                </span>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            if(!searchInput) return;

            const clearBtn = document.getElementById('clearSearch');
            const clearAllBtn = document.getElementById('clearAll');
            const rows = document.querySelectorAll('.curso-row');
            const noResults = document.getElementById('noResults');
            const countEl = document.getElementById('count');

            function filterTable() {
                const query = searchInput.value.toLowerCase().trim();
                let visibleCount = 0;

                rows.forEach(row => {
                    const text = row.getAttribute('data-search') || '';
                    const matches = text.includes(query);
                    row.style.display = matches ? '' : 'none';
                    if (matches) visibleCount++;
                });

                countEl.textContent = visibleCount;
                if(noResults) noResults.classList.toggle('hidden', visibleCount > 0);
                if(clearBtn) clearBtn.classList.toggle('hidden', query === '');
            }

            let timeout;
            searchInput.addEventListener('input', () => {
                clearTimeout(timeout);
                timeout = setTimeout(filterTable, 150);
            });

            if(clearBtn) {
                clearBtn.addEventListener('click', () => {
                    searchInput.value = '';
                    filterTable();
                    searchInput.focus();
                });
            }

            if(clearAllBtn) {
                clearAllBtn.addEventListener('click', () => {
                    searchInput.value = '';
                    filterTable();
                    searchInput.focus();
                });
            }
        });
    </script>
}