@model Inkillay.Certificados.Web.Models.ViewModels.MatricularViewModel
@{
    ViewData["Title"] = "Matricular Alumno";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white border border-slate-300 rounded-sm shadow-sm">
        <div class="p-4 border-b border-slate-300 bg-slate-50">
            <h3 class="text-xs font-bold text-slate-600 uppercase tracking-wider">Registrar Nueva Matrícula</h3>
        </div>

        <form id="formMatricular" method="post" class="p-6 space-y-5">
            @Html.AntiForgeryToken()

            <div class="space-y-2">
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider">Curso</label>
                <select name="idCurso" required
                        class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm focus:ring-1 focus:ring-primary focus:border-primary">
                    <option value="">-- Seleccionar Curso --</option>
                    @foreach (var curso in Model.Cursos)
                    {
                        <option value="@curso.IdCurso">@curso.Nombre (S/ @curso.Costo.ToString("N2"))</option>
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider">Alumno</label>
                <select name="idAlumno" required
                        class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm focus:ring-1 focus:ring-primary focus:border-primary">
                    <option value="">-- Seleccionar Alumno --</option>
                    @foreach (var alumno in Model.Alumnos)
                    {
                        <option value="@alumno.IdUsuario">@alumno.Nombre (@alumno.Correo)</option>
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider">Modalidad</label>
                <select name="modalidad" required
                        class="w-full px-3 py-2 border border-slate-300 rounded-sm text-sm focus:ring-1 focus:ring-primary focus:border-primary">
                    <option value="">-- Seleccionar Modalidad --</option>
                    <option value="P">Presencial</option>
                    <option value="V">Virtual</option>
                    <option value="H">Hibrida</option>
                </select>
            </div>

            <div class="pt-4 border-t border-slate-300 flex gap-3">
                <button type="submit"
                        class="flex-1 py-2 bg-primary text-white text-xs font-bold uppercase rounded-sm hover:bg-sky-800">
                    Matricular
                </button>
                <a href="@Url.Action("Index")"
                       class="flex-1 py-2 bg-slate-200 text-slate-700 text-xs font-bold uppercase rounded-sm hover:bg-slate-300 text-center">
                    Volver
                </a>
            </div>
        </form>

        <div id="mensajeResultado" class="px-6 pb-6"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('formMatricular').addEventListener('submit', async function (e) {
        e.preventDefault();

        const formData = new FormData(this);

        try {
        const response = await fetch('@Url.Action("Matricular")', {
        method: 'POST',
        body: formData
        });

        const data = await response.json();

        if (data.success) {
        await Swal.fire({
        title: '✓ Éxito',
        text: data.mensaje,
        icon: 'success',
        confirmButtonColor: '#0369a1'
        });

        this.reset();
        } else {
        Swal.fire({
        title: 'Error',
        text: data.mensaje,
        icon: 'error',
        confirmButtonColor: '#0369a1'
        });
        }
        } catch (error) {
        console.error('Error:', error);
        Swal.fire({
        title: 'Error',
        text: 'No se pudo registrar la matrícula.',
        icon: 'error',
        confirmButtonColor: '#0369a1'
        });
        }
        });
    </script>
}