@model Inkillay.Certificados.Web.Models.ViewModels.EmisionIndexViewModel
@{
    ViewData["Title"] = "Emision de Certificados";
}

<div class="bg-white rounded-sm border border-slate-300 shadow-sm">
    <div class="p-6 border-b border-slate-300">
        <div class="flex flex-col md:flex-row gap-4 items-end justify-between">
            <form method="get" asp-controller="Emision" asp-action="Index" class="flex flex-col md:flex-row gap-3 items-end">
                <div>
                    <label class="block text-xs font-bold uppercase text-slate-600 mb-1">Curso</label>
                    <select name="idCurso" class="px-3 py-2 border border-slate-300 rounded-sm text-sm text-slate-700 focus:ring-1 focus:ring-primary focus:border-primary">
                        <option value="">Seleccionar curso...</option>
                        @foreach (var curso in Model.Cursos)
                        {
                            if (Model.IdCursoSeleccionado == curso.IdCurso)
                            {
                                <option value="@curso.IdCurso" selected>@curso.Nombre</option>
                            }
                            else
                            {
                                <option value="@curso.IdCurso">@curso.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <button type="submit" class="px-4 py-2 bg-primary text-white text-xs font-bold rounded-sm hover:bg-sky-800">Ver Alumnos</button>
            </form>

            <form id="formGenerar" asp-controller="Emision" asp-action="GenerarCertificados" method="post" class="flex flex-col md:flex-row gap-3 items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="idCurso" id="hiddenIdCurso" value="@(Model.IdCursoSeleccionado ?? 0)" />
                <div>
                    <label class="block text-xs font-bold uppercase text-slate-600 mb-1">Plantilla</label>
                    <select name="idPlantilla" required class="px-3 py-2 border border-slate-300 rounded-sm text-sm text-slate-700 focus:ring-1 focus:ring-primary focus:border-primary">
                        <option value="">Seleccionar plantilla...</option>
                        @foreach (var p in Model.Plantillas.Where(p => p.EstadoActivo))
                        {
                            <option value="@p.IdPlantilla">[@p.IdPlantilla] @p.Nombre</option>
                        }
                    </select>
                </div>
                <button type="submit" class="px-4 py-2 bg-green-700 text-white text-xs font-bold rounded-sm hover:bg-green-800">
                    Generar Certificados
                </button>
            </form>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm border-collapse">
            <thead class="bg-slate-100 border-b border-slate-300 text-slate-700">
                <tr>
                    <th class="px-4 py-3 border-r border-slate-200 font-semibold text-xs uppercase tracking-wide">ID</th>
                    <th class="px-4 py-3 border-r border-slate-200 font-semibold text-xs uppercase tracking-wide">Alumno</th>
                    <th class="px-4 py-3 border-r border-slate-200 font-semibold text-xs uppercase tracking-wide">Curso</th>
                    <th class="px-4 py-3 border-r border-slate-200 font-semibold text-xs uppercase tracking-wide">Fecha</th>
                    <th class="px-4 py-3 border-r border-slate-200 font-semibold text-xs uppercase tracking-wide">Aprobado</th>
                    <th class="px-4 py-3 border-r border-slate-200 font-semibold text-xs uppercase tracking-wide">Estado</th>
                    <th class="px-4 py-3 text-center font-semibold text-xs uppercase tracking-wide">Acción</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 text-slate-700">
                @if (!Model.Alumnos.Any())
                {
                    <tr>
                        <td colspan="7" class="px-4 py-6 text-sm text-slate-500 text-center">No hay alumnos para el curso seleccionado.</td>
                    </tr>
                }
                else
                {
                    @foreach (var alumno in Model.Alumnos)
                    {
                        <tr class="hover:bg-gray-50 transition-colors border-b last:border-0">
                            <td class="px-6 py-4 border-r border-slate-200">@alumno.IdMatricula</td>
                            <td class="px-6 py-4 border-r border-slate-200">
                                <div class="font-medium text-gray-900">@alumno.NombreAlumno</div>
                            </td>
                            <td class="px-6 py-4 border-r border-slate-200">@alumno.NombreCurso</td>
                            <td class="px-6 py-4 border-r border-slate-200">-</td>
                            <td class="px-6 py-4 border-r border-slate-200">
                                @if (alumno.Aprobado)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        Aprobado
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                        No Aprobado
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 border-r border-slate-200">
                                <span class="text-sm @(alumno.TotalPagado >= alumno.CostoCurso ? "text-green-600 font-semibold" : "text-amber-600")">
                                    S/ @alumno.TotalPagado.ToString("F2") / S/ @alumno.CostoCurso.ToString("F2")
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                @if (alumno.Aprobado && alumno.TotalPagado >= alumno.CostoCurso)
                                {
                                    <a href="/Emision/DescargarPdf?idModulo=@alumno.IdMatricula" 
                                       class="btn-emitir inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold rounded-lg transition-all shadow-sm">
                                        <span class="material-symbols-outlined text-sm">download</span>
                                        Descargar
                                    </a>
                                }
                                else
                                {
                                    <button disabled class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-400 text-xs font-bold rounded-lg cursor-not-allowed">
                                        <span class="material-symbols-outlined text-sm">lock</span>
                                        Pendiente
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $('#formGenerar').on('submit', function(e) {
            e.preventDefault();
            const $form = $(this);

            $.post($form.attr('action'), $form.serialize(), function(res) {
                if (res.success) {
                    Swal.fire({ title: '✓ Éxito', text: 'Certificados generados: ' + res.totalGenerados, icon: 'success', confirmButtonColor: '#0369a1' }).then(() => location.reload());
                } else {
                    Swal.fire({ title: 'Error', text: res.message || 'No se pudo generar.', icon: 'error', confirmButtonColor: '#0369a1' });
                }
            }).fail(function() {
                Swal.fire({ title: 'Error', text: 'Error al generar certificados.', icon: 'error', confirmButtonColor: '#0369a1' });
            });
        });
    </script>
}
