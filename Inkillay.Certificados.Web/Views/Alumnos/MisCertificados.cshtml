@model IEnumerable<SIGEC.Certificados.Web.Models.Entities.Matricula>
@{
    ViewData["Title"] = "Expediente de Certificados";
}

<div class="px-4 py-8 max-w-6xl mx-auto">
    
    <!-- Encabezado y Acción Principal -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600">workspace_premium</span>
                Expediente de Certificados
            </h1>
            <p class="text-sm text-slate-500 mt-1">Consulta y descarga de documentos académicos oficiales expedidos a tu nombre.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <!-- Estado Vacío Mejorado -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-12 text-center max-w-3xl mx-auto">
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner border border-slate-100">
                <span class="material-symbols-outlined text-5xl text-slate-300">folder_open</span>
            </div>
            <h3 class="text-lg font-black text-slate-800 tracking-tight mb-2 uppercase">Sin Certificados Emitidos</h3>
            <p class="text-sm text-slate-500 mb-8 px-4">
                No se registran certificados disponibles para impresión. Para obtener su certificado oficial, asegúrese de cumplir con los siguientes requisitos:
            </p>
            
            <div class="bg-slate-50 rounded-xl p-6 text-left max-w-sm mx-auto border border-slate-100">
                <ul class="text-sm text-slate-700 font-medium space-y-4">
                    <li class="flex items-center gap-3">
                        <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-[14px]">check</span>
                        </div>
                        Completar el módulo al 100%
                    </li>
                    <li class="flex items-center gap-3">
                        <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-[14px]">check</span>
                        </div>
                        Tener calificación final aprobatoria
                    </li>
                    <li class="flex items-center gap-3">
                        <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-[14px]">check</span>
                        </div>
                        Cancelar totalidad del costo
                    </li>
                </ul>
            </div>
        </div>
    }
    else
    {
        <!-- Tabla de Certificados (Gold Standard) -->
        <div class="bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden overflow-x-auto mb-8">
            <table class="min-w-full divide-y divide-slate-200 align-middle text-sm whitespace-nowrap">
                <thead class="bg-slate-50 border-b border-slate-200 hidden sm:table-header-group">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Identificador</th>
                        <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Programa Acreditado</th>
                        <th scope="col" class="px-6 py-4 text-right font-bold text-slate-500 uppercase tracking-widest text-[10px]">Fecha Registro</th>
                        <th scope="col" class="px-6 py-4 text-center font-bold text-slate-500 uppercase tracking-widest text-[10px]">Estado Legal</th>
                        <th scope="col" class="px-6 py-4 text-right font-bold text-slate-500 uppercase tracking-widest text-[10px] rounded-tr-xl">Descarga</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white">
                    @foreach (var item in Model)
                    {
                        var listo = item.Aprobado && item.TotalPagado >= item.CostoCurso;
                        
                        <tr class="hover:bg-indigo-50/40 transition-colors group">
                            
                            <!-- Columna: ID -->
                            <td class="px-6 py-4">
                                <span class="inline-flex font-mono text-xs font-semibold text-slate-500 bg-slate-100 px-2 py-1 rounded border border-slate-200">
                                    #MAT-@item.IdMatricula.ToString("D5")
                                </span>
                            </td>
                            
                            <!-- Columna: Curso -->
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center flex-shrink-0 border border-indigo-100">
                                        <span class="material-symbols-outlined text-[16px]">school</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-slate-800">@item.NombreCurso</span>
                                        <span class="text-[11px] text-slate-400 font-medium tracking-wide uppercase">Acreditación Académica</span>
                                    </div>
                                </div>
                            </td>
                            
                            <!-- Columna: Fecha -->
                            <td class="px-6 py-4 text-right">
                                <span class="font-medium text-slate-600">@(item.FechaRegistro?.ToString("dd MMM yyyy"))</span>
                            </td>

                            <!-- Columna: Estado -->
                            <td class="px-6 py-4 text-center">
                                @if (listo)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800 border border-emerald-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-sm"></span>
                                        Emitido
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-amber-100 text-amber-800 border border-amber-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 shadow-sm"></span>
                                        En Trámite
                                    </span>
                                }
                            </td>

                            <!-- Columna: Acciones -->
                            <td class="px-6 py-4 text-right">
                                @if (listo)
                                {
                                    <a href="@Url.Action("DescargarPdf", "Emision", new { idModulo = item.IdMatricula })" 
                                       class="inline-flex items-center justify-end gap-1.5 px-3 py-1.5 bg-indigo-50 text-indigo-700 hover:bg-indigo-600 hover:text-white text-xs font-bold rounded-lg transition-colors border border-indigo-200 shadow-sm">
                                        <span class="material-symbols-outlined text-[18px]">download</span> PDF Original
                                    </a>
                                }
                                else
                                {
                                    <span class="inline-flex items-center justify-end gap-1 px-3 py-1.5 text-slate-400 text-xs font-medium">
                                        <span class="material-symbols-outlined text-[16px]">hourglass_empty</span> Pendiente
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Info Box Premium -->
        <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-5 flex items-start gap-4 shadow-sm">
            <div class="w-10 h-10 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center flex-shrink-0 shadow-inner">
                <span class="material-symbols-outlined">info</span>
            </div>
            <div>
                <h4 class="font-bold text-indigo-900 text-sm tracking-wide uppercase mb-1">Nota Importante de Emisión</h4>
                <p class="text-sm text-indigo-800/80 leading-relaxed font-medium">
                    Los certificados solo están habilitados para su descarga cuando el sistema registra la condición de <strong>aprobado</strong> y el expediente financiero está <strong>cancelado en su totalidad</strong>. Si detectas alguna discrepancia, contacta con secretaría.
                </p>
            </div>
        </div>
    }
</div>
