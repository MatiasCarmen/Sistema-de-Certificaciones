@model IEnumerable<Inkillay.Certificados.Web.Models.Entities.Modulo>
@{
    ViewData["Title"] = "Expediente de Certificados";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="border-b border-slate-300 pb-4">
        <h1 class="text-xl font-bold text-slate-800 tracking-tight">EXPEDIENTE DE CERTIFICADOS</h1>
        <p class="text-xs text-slate-500 uppercase font-semibold mt-1">Consulta y descarga de documentos académicos oficiales</p>
    </div>

    <!-- Tabla o Mensaje Vacío -->
    @if (!Model.Any())
    {
        <div class="bg-white border border-slate-300 rounded-sm shadow-sm p-12 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-300 block mb-3">folder_open</span>
            <h3 class="text-sm font-bold text-slate-700 mb-2">SIN CERTIFICADOS DISPONIBLES</h3>
            <p class="text-xs text-slate-500 mb-6 max-w-sm mx-auto">
                No se registran certificados emitidos a su nombre. Para obtener un certificado debe:
            </p>
            <ul class="text-xs text-slate-600 space-y-2 inline-block text-left">
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-green-600">check_circle</span>
                    Completar el curso
                </li>
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-green-600">check_circle</span>
                    Obtener calificación aprobatoria
                </li>
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-green-600">check_circle</span>
                    Cancelar la matrícula completamente
                </li>
            </ul>
        </div>
    }
    else
    {
        <!-- Tabla de Certificados -->
        <div class="bg-white border border-slate-300 shadow-sm rounded-sm overflow-hidden">
            <table class="w-full text-left text-sm border-collapse">
                <thead class="bg-slate-100 border-b border-slate-300 text-slate-700">
                    <tr>
                        <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Código</th>
                        <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Programa / Curso</th>
                        <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase">Fecha Emisión</th>
                        <th class="px-4 py-2 border-r border-slate-200 font-semibold text-xs uppercase text-center">Estado</th>
                        <th class="px-4 py-2 font-semibold text-xs uppercase text-center">Acción</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 text-slate-600">
                    @foreach (var item in Model)
                    {
                        var listo = item.Aprobado && item.TotalPagado >= item.CostoCurso;
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-2 border-r border-slate-200 font-mono text-[11px]">#MAT-@item.IdModulo</td>
                            <td class="px-4 py-2 border-r border-slate-200">
                                <div class="font-bold text-slate-800 text-sm">@item.NombreCurso</div>
                                <div class="text-[10px] text-slate-400 uppercase">Acreditación Académica</div>
                            </td>
                            <td class="px-4 py-2 border-r border-slate-200 text-[12px]">@item.FechaModulo.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-2 border-r border-slate-200 text-center">
                                @if (listo)
                                {
                                    <span class="px-2 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] font-bold uppercase rounded-sm border border-emerald-200">Emitido</span>
                                }
                                else
                                {
                                    <span class="px-2 py-0.5 bg-slate-100 text-slate-500 text-[10px] font-bold uppercase rounded-sm border border-slate-300">En Trámite</span>
                                }
                            </td>
                            <td class="px-4 py-2 text-center">
                                @if (listo)
                                {
                                    <a href="@Url.Action("DescargarPdf", "Emision", new { idModulo = item.IdModulo })" 
                                       class="inline-flex items-center px-3 py-1 bg-blue-600 text-white text-[11px] font-bold rounded-sm hover:bg-blue-700 transition-none">
                                        <span class="material-symbols-outlined text-sm mr-1">download</span> PDF
                                    </a>
                                }
                                else
                                {
                                    <span class="text-[10px] text-slate-400 italic">No disponible</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Info Box -->
        <div class="p-4 bg-blue-50 border-l-4 border-blue-600 rounded-sm">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-blue-600 flex-shrink-0">info</span>
                <div class="text-xs text-blue-900">
                    <p class="font-bold uppercase mb-1">Importante</p>
                    <p>Los certificados solo están disponibles con estado <strong>Aprobado</strong> y <strong>pago completado</strong>. En caso de discrepancias, contacta con tesorería.</p>
                </div>
            </div>
        </div>
    }
</div>

