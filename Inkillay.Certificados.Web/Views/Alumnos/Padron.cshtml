@model IEnumerable<UsuarioViewModel>
@{
    ViewData["Title"] = "Directorio de Alumnos";
}

<div class="px-4 py-8">
    
    @Html.AntiForgeryToken()

    <!-- Encabezado y Acción Principal -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600">groups</span>
                Padrón de Estudiantes
            </h1>
            <p class="text-sm text-slate-500 mt-1">Gestión y visualización del padrón general de alumnos inscritos en el sistema.</p>
        </div>
        
        <a href="@Url.Action("Create", "Usuarios")" class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-bold text-white shadow transition hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 uppercase tracking-wide shrink-0">
            <span class="material-symbols-outlined text-[18px]">person_add</span>
            Inscribir Alumno
        </a>
    </div>

    <!-- Filtros / Búsqueda -->
    <div class="bg-white rounded-t-xl border-x border-t border-slate-200 p-4 shadow-sm flex items-center justify-between">
        <div class="relative w-full max-w-sm">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                <span class="material-symbols-outlined text-[18px]">search</span>
            </span>
            <input type="text" id="buscadorAlumnos" placeholder="Buscar por nombre o correo electrónico..." class="w-full pl-10 pr-4 py-2 text-sm border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition shadow-sm outline-none">
        </div>
        <div class="text-sm text-slate-500 font-medium hidden sm:block">
            Mostrando: <span id="contador" class="text-slate-900 font-bold">@Model.Count()</span> alumnos
        </div>
    </div>

    <!-- Tabla Principal (Gold Standard) -->
    <div class="bg-white shadow-sm border border-slate-200 rounded-b-xl overflow-hidden overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 align-middle text-sm whitespace-nowrap" id="tablaAlumnos">
            <thead class="bg-slate-50 border-b border-slate-200 hidden sm:table-header-group">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Estudiante / Avatar</th>
                    <th scope="col" class="px-6 py-4 text-left font-bold text-slate-500 uppercase tracking-widest text-[10px]">Contacto Institucional</th>
                    <th scope="col" class="px-6 py-4 text-center font-bold text-slate-500 uppercase tracking-widest text-[10px]">Estado Operativo</th>
                    <th scope="col" class="px-6 py-4 text-right font-bold text-slate-500 uppercase tracking-widest text-[10px]">Primera Inscripción</th>
                    <th scope="col" class="px-6 py-4 text-right font-bold text-slate-500 uppercase tracking-widest text-[10px] rounded-tr-xl">Acciones Rápidas</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                
                @if (!Model.Any())
                {
                    <tr class="alumno-row">
                        <td colspan="5" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center justify-center text-slate-400">
                                <span class="material-symbols-outlined text-6xl mb-3 text-slate-300">group_off</span>
                                <p class="text-base font-medium text-slate-600">No hay alumnos registrados</p>
                                <p class="text-sm mt-1">El padrón está vacío actualmente.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var alumno in Model)
                    {
                        <tr class="alumno-row hover:bg-indigo-50/40 transition-colors group" data-nombre="@alumno.Nombre.ToLower()" data-correo="@alumno.Correo.ToLower()">
                            
                            <!-- Columna: Nombre / Avatar -->
                            <td class="px-6 py-4 text-left">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center flex-shrink-0 shadow-sm border border-indigo-200 font-bold text-xs uppercase">
                                        @((!string.IsNullOrEmpty(alumno.Nombre) ? alumno.Nombre.Substring(0, 1) : "?").ToUpper())
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-slate-800">@alumno.Nombre</span>
                                        <span class="text-[11px] font-medium text-slate-500">ID: #@alumno.IdUsuario.ToString("D4")</span>
                                    </div>
                                </div>
                            </td>
                            
                            <!-- Columna: Correo -->
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2 text-slate-600 font-medium">
                                    <span class="material-symbols-outlined text-[16px] text-slate-400">mail</span>
                                    @alumno.Correo
                                </div>
                            </td>
                            
                            <!-- Columna: Estado -->
                            <td class="px-6 py-4 text-center">
                                @if (alumno.Estado)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800 border border-emerald-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-sm"></span>
                                        Regular
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-rose-100 text-rose-800 border border-rose-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-rose-500 shadow-sm"></span>
                                        Inactivo
                                    </span>
                                }
                            </td>

                            <!-- Columna: Fecha Registro -->
                            <td class="px-6 py-4 text-right">
                                <span class="font-semibold text-slate-700">@alumno.FechaRegistro.ToString("dd MMM yyyy")</span>
                            </td>

                            <!-- Columna: Acciones -->
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-1 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                                    
                                    <a href="@Url.Action("EditAlumno", "Usuarios", new { id = alumno.IdUsuario })" class="p-2 text-indigo-600 hover:bg-indigo-100 rounded-lg transition-colors group/btn tooltip" title="Editar Ficha">
                                        <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">edit_document</span>
                                    </a>
                                    
                                    <button type="button" onclick="cambiarEstado(@alumno.IdUsuario, @((!alumno.Estado).ToString().ToLower()), '@alumno.Nombre')"
                                            class="p-2 @(alumno.Estado ? "text-amber-600 hover:bg-amber-100" : "text-emerald-600 hover:bg-emerald-100") rounded-lg transition-colors group/btn tooltip" 
                                            title="@(alumno.Estado ? "Dar de Baja" : "Reactivar")">
                                        <span class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform">
                                            @(alumno.Estado ? "person_remove" : "how_to_reg")
                                        </span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        
        <!-- Estado Vacío por Búsqueda -->
        <div id="noResultados" class="hidden px-6 py-12 text-center border-t border-slate-100">
            <div class="flex flex-col items-center justify-center text-slate-400">
                <span class="material-symbols-outlined text-4xl mb-2 text-slate-300">search_off</span>
                <p class="text-sm font-medium text-slate-500">No se encontraron alumnos que coincidan con la búsqueda.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const buscadorInput = document.getElementById('buscadorAlumnos');
            const filas = document.querySelectorAll('.alumno-row');
            const contadorDisplay = document.getElementById('contador');
            const noResultadosCaja = document.getElementById('noResultados');

            buscadorInput.addEventListener('input', function(e) {
                const term = e.target.value.toLowerCase().trim();
                let matchCount = 0;

                filas.forEach(fila => {
                    if(!fila.dataset.nombre) return; // Ignore empty state row if present

                    const nombre = fila.dataset.nombre;
                    const correo = fila.dataset.correo;

                    if (nombre.includes(term) || correo.includes(term)) {
                        fila.style.display = '';
                        matchCount++;
                    } else {
                        fila.style.display = 'none';
                    }
                });

                contadorDisplay.textContent = matchCount;

                if (matchCount === 0 && filas.length > 0 && term !== "") {
                    noResultadosCaja.classList.remove('hidden');
                } else {
                    noResultadosCaja.classList.add('hidden');
                }
            });
        });

        function cambiarEstado(id, nuevoEstado, nombre) {
            const accion = nuevoEstado ? 'reactivar' : 'dar de baja';
            const accionConfirmButton = nuevoEstado ? 'Sí, reactivar' : 'Sí, dar de baja';
            
            Swal.fire({
                title: '¿Estás seguro?',
                text: `¿Deseas ${accion} a ${nombre}?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#4f46e5', // indigo-600
                cancelButtonColor: '#94a3b8', // slate-400
                confirmButtonText: accionConfirmButton,
                cancelButtonText: 'Cancelar',
                customClass: {
                    title: 'text-lg font-bold text-slate-800',
                    popup: 'rounded-2xl shadow-xl border border-slate-200',
                    confirmButton: 'rounded-lg px-6 py-2.5 font-bold',
                    cancelButton: 'rounded-lg px-6 py-2.5 font-bold'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const formData = new FormData();
                    formData.append('idUsuario', id);
                    formData.append('estado', nuevoEstado);
                    if(token) formData.append('__RequestVerificationToken', token);

                    fetch('@Url.Action("CambiarEstado", "Usuarios")', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                title: '¡Actualizado!',
                                text: data.mensaje,
                                icon: 'success',
                                confirmButtonColor: '#4f46e5',
                                customClass: { popup: 'rounded-2xl shadow-xl' }
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire('Error', data.mensaje, 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        Swal.fire('Error', 'Ocurrió un error inesperado', 'error');
                    });
                }
            });
        }
    </script>
}
